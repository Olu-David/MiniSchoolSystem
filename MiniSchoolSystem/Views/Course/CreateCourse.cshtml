@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserDb> SigInManager;
@inject UserManager<UserDb> UserManager;


@model MiniSchoolSystem.DTO.CreateCourseViewDTO
@{
    ViewData["Title"] = "Create Course";
     if (User.IsInRole("SuperAdmin"))
    {
        Layout = "~/Views/Shared/_SuperAdminSidebar.cshtml";
    }
    Layout = "~/Views/Shared/_Layout.cshtml";

    var sections = ViewBag.CourseSection as List<MiniSchoolSystem.Enums.Sections>
                   ?? Enum.GetValues(typeof(MiniSchoolSystem.Enums.Sections))
                          .Cast<MiniSchoolSystem.Enums.Sections>().ToList();
}

@section Styles {
<link rel="stylesheet" href="~/css/SabiSpace.css" asp-append-version="true" />
}

<div class="course-page">
   
    <!-- HEADER -->
    <div class="page-header">
        <div class="ph-blob phb1" style="background:rgba(255,92,26,.12)"></div>
        <div class="ph-blob phb2" style="background:rgba(245,200,66,.07)"></div>
        <div class="ph-inner">
            <div>
                <div class="breadcrumb">
                    <a asp-controller="Home"   asp-action="Index">Home</a><span>›</span>
                    <a asp-controller="Course" asp-action="Index">Courses</a><span>›</span>
                    <span style="color:var(--text-secondary)">Create Course</span>
                </div>
                <h1 class="ph-title">Create a New Course</h1>
                <p class="ph-sub">Fill in the details below and your course will be ready for modules and lessons.</p>
            </div>
        </div>
    </div>

    <!-- FORM -->
    <div class="form-wrap">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-err">
                <span>⚠️</span>
                <div>@Html.ValidationSummary(false)</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-err"><span>⚠️</span><span>@TempData["Error"]</span></div>
        }

        <form asp-controller="Course" asp-action="CreateCourse"
              method="post" id="createForm">
            @Html.AntiForgeryToken()

            <!-- Card 1: Core info -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-title">📋 Course Details</div>
                    <span class="form-card-badge">Required</span>
                </div>

                <div class="fg">
                    <label asp-for="Title">Course Title</label>
                    <input asp-for="Title" class="field"
                           placeholder="e.g. Complete Web Development for SS3"
                           maxlength="120"
                           oninput="countChars(this,'titleCount',120)" />
                    <div class="char-count" id="titleCount">0 / 120</div>
                    <span asp-validation-for="Title" class="field-error"></span>
                </div>

                <div class="fg">
                    <label asp-for="Description">Description <span style="font-weight:400;color:var(--text-dim)">(optional)</span></label>
                    <textarea asp-for="Description" class="field"
                              placeholder="What will students learn in this course?"
                              rows="4" maxlength="500"
                              oninput="countChars(this,'descCount',500)"></textarea>
                    <div class="char-count" id="descCount">0 / 500</div>
                </div>

              </div>
            <!-- Actions -->
            <div class="form-actions">
                <a asp-controller="Course" asp-action="Index" class="btn btn-ghost">← Cancel</a>
                <button type="submit" class="btn btn-sabi" id="submitBtn"
                        onclick="handleSubmit()">
                    <span class="btn-spin" id="submitSpin"></span>
                    <span id="submitTxt">Create Course →</span>
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/SabiSpace.js" asp-append-version="true"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
function countChars(el, id, max) {
    var len = el.value.length;
    var el2 = document.getElementById(id);
    el2.textContent = len + ' / ' + max;
    el2.className = 'char-count' + (len > max*.9 ? ' warn' : '');
}
function handleSubmit() {
    var title = document.querySelector('[name="Title"]').value.trim();
    var sec   = document.querySelector('[name="SelectedSection"]').value;
    if (!title || !sec) return false;
    var btn = document.getElementById('submitBtn');
    var spin = document.getElementById('submitSpin');
    var txt  = document.getElementById('submitTxt');
    btn.disabled = true; spin.style.display = 'block'; txt.textContent = 'Creating…';
}
</script>
}
