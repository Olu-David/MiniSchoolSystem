@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Org.BouncyCastle.Asn1.Ocsp
@inject SignInManager<UserDb> SignInManager
@inject UserManager<UserDb> UserManager
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Archive Lesson";

    if (User.IsInRole("SuperAdmin"))
    {
        Layout = "~/Views/Shared/_SuperAdminSidebar.cshtml";
    }
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userRole = User.FindFirstValue(ClaimTypes.Role);
    var displayName = User.Identity?.Name ?? "User";

    bool isAllowedRole = User.IsInRole("SuperAdmin")
                      || User.IsInRole("Admin")
                      || User.IsInRole("Teacher")
                      || User.IsInRole("Student");

    bool isBlockedUser = User.Identity!.IsAuthenticated && !isAllowedRole;
    bool isLoggedIn = User.Identity!.IsAuthenticated;

    // Fix: Use HttpContextAccessor to access query string
    var qsId = HttpContextAccessor.HttpContext?.Request.Query["id"].ToString();
}

@section Styles {
    <link rel="stylesheet" href="~/css/SabiSpace.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Lesson.css" asp-append-version="true" />
}

@if (isBlockedUser)
{
    <div style="padding:40px;text-align:center">
        <h2>Access Restricted</h2>
        <p>Your account doesn't have a recognised role. Contact support.</p>
    </div>
}
else
{
    @if (User.IsInRole("SuperAdmin"))
    {
        @await Html.PartialAsync("_SabiSpaceSidebar")
    }

    <div class="page-centered">
        <div class="blob blob-gold   blob-tl"></div>
        <div class="blob blob-orange blob-br" style="opacity:.4"></div>

        <div class="confirm-card border-gold">

            <div class="card-icon gold">📦</div>
            <h1 class="card-title">Archive this lesson?</h1>
            <p class="card-sub">
                Archiving hides the lesson from students but
                <strong class="sage">keeps all the data safe</strong>.
                You can restore it anytime.
            </p>

            <!-- Lesson preview -->
            <div class="lesson-preview">
                <div class="lesson-preview-label">Lesson to archive</div>
                <div class="lesson-preview-title" id="lpTitle">Loading…</div>
                <div class="lesson-preview-desc" id="lpDesc"></div>
                <div class="lesson-preview-meta">
                    <span id="lpDate">—</span>
                    <span class="section-tag" id="lpSection" style="display:none"></span>
                </div>
            </div>

            <!-- What archive means -->
            <div class="warn-box warn-box-gold">
                <span class="warn-box-icon">ℹ️</span>
                <div>
                    <p class="warn-box-title">What archiving does</p>
                    <ul class="warn-list">
                        <li>Lesson is hidden from student search and listings</li>
                        <li>All content, files and data are kept intact</li>
                        <li>A Teacher or SuperAdmin can restore it at any time</li>
                        <li>No students are notified</li>
                    </ul>
                </div>
            </div>

            <!-- Confirm checkbox -->
            <div class="confirm-check gold">
                <input type="checkbox" id="confirmCheck"
                       onchange="toggleConfirmBtn('confirmCheck','archiveBtn')" />
                <label for="confirmCheck">
                    I want to archive
                    <strong style="color:var(--text-primary)" id="confirmTitle">this lesson</strong>
                </label>
            </div>

            <!-- Buttons -->
            <form id="archiveForm" asp-controller="Lesson" asp-action="ArchiveLesson" asp-route-id="@(qsId)" method="post" style="display:contents">
                @Html.AntiForgeryToken()
                <input type="hidden" id="Id" name="id" value="@(qsId)" />
                <div class="confirm-btns">
                    <a asp-controller="Lesson" asp-action="Index" class="btn btn-ghost btn-block">← Cancel</a>
                    <button type="submit" class="btn btn-gold btn-block"
                            id="archiveBtn" disabled
                            onclick="showSubmitSpinner('archiveBtn','archSpin','archTxt','Archiving…')">
                        <span class="btn-spin" id="archSpin"
                              style="border-color:rgba(254,243,199,.3);border-top-color:#fef3c7"></span>
                        <span id="archTxt">📦 Archive Lesson</span>
                    </button>
                </div>
            </form>

        </div>
    </div>

    @section Scripts {
        <script src="~/js/lesson.js" asp-append-version="true"></script>
        <script>
            (function(){
                // lesson id from query or URL helper
                var lessonId = new URLSearchParams(location.search).get('id') || getLessonIdFromUrl();

                // Load list (or call an API that returns a single lesson) and populate preview fields
                fetch('/Lesson/GetLessons')
                    .then(function(r){ return r.json(); })
                    .then(function(lessons){
                        var l = lessons.find(function(x){ return String(x.id) === String(lessonId); });
                        if(!l) return;
                        document.getElementById('lpTitle').textContent      = l.title || 'Lesson';
                        document.getElementById('lpDesc').textContent       = l.description || '';
                        document.getElementById('lpDate').textContent       = '📅 ' + fmtDate(l.createdAt);
                        document.getElementById('confirmTitle').textContent = l.title || 'this lesson';
                        if(l.lessonSection){
                            var s = document.getElementById('lpSection');
                            s.textContent = l.lessonSection;
                            s.style.display = 'inline-block';
                        }
                        // Ensure form hidden id matches loaded id
                        var hidden = document.getElementById('Id');
                        if(hidden) hidden.value = l.id;
                        // If qsId was empty, update form action to include id
                        var form = document.getElementById('archiveForm');
                        if(form && (!form.getAttribute('asp-route-id') || form.getAttribute('asp-route-id')==='')) {
                            form.action = '/Lesson/ArchiveLesson?id=' + l.id;
                        }
                    })
                    .catch(function(){
                        // ignore — preview remains minimal
                    });

                // enable/disable confirm button helper exists in SabiSpace.js
                // toggleConfirmBtn('confirmCheck','archiveBtn') already wired via onchange in markup
            })();
        </script>
    }
}
