<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Archive Lesson — SabiSpace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="../css/lesson.css" />
</head>
<body>

    <div class="page-centered">
        <div class="blob blob-gold   blob-tl"></div>
        <div class="blob blob-orange blob-br" style="opacity:.4"></div>

        <div class="confirm-card border-gold">

            <div class="card-icon gold">📦</div>
            <h1 class="card-title">Archive this lesson?</h1>
            <p class="card-sub">
                Archiving hides the lesson from students but
                <strong class="sage">keeps all the data safe</strong>.
                You can restore it anytime.
            </p>

            <!-- Lesson preview -->
            <div class="lesson-preview">
                <div class="lesson-preview-label">Lesson to archive</div>
                <div class="lesson-preview-title" id="lpTitle">Loading…</div>
                <div class="lesson-preview-desc" id="lpDesc"></div>
                <div class="lesson-preview-meta">
                    <span id="lpDate">—</span>
                    <span class="section-tag" id="lpSection" style="display:none"></span>
                </div>
            </div>

            <!-- What archive means -->
            <div class="warn-box warn-box-gold">
                <span class="warn-box-icon">ℹ️</span>
                <div>
                    <p class="warn-box-title">What archiving does</p>
                    <ul class="warn-list">
                        <li>Lesson is hidden from student search and listings</li>
                        <li>All content, files and data are kept intact</li>
                        <li>A Teacher or SuperAdmin can restore it at any time</li>
                        <li>No students are notified</li>
                    </ul>
                </div>
            </div>

            <!-- Confirm checkbox -->
            <div class="confirm-check gold">
                <input type="checkbox" id="confirmCheck"
                       onchange="toggleConfirmBtn('confirmCheck','archiveBtn')" />
                <label for="confirmCheck">
                    I want to archive
                    <strong style="color:var(--text-primary)" id="confirmTitle">this lesson</strong>
                </label>
            </div>

            <!-- Buttons -->
            <form id="archiveForm" method="post" style="display:contents">
                <!-- @Html.AntiForgeryToken() -->
                <div class="confirm-btns">
                    <a href="/Lesson" class="btn btn-ghost btn-block">← Cancel</a>
                    <button type="submit" class="btn btn-gold btn-block"
                            id="archiveBtn" disabled
                            onclick="showSubmitSpinner('archiveBtn','archSpin','archTxt','Archiving…')">
                        <span class="btn-spin" id="archSpin"
                              style="border-color:rgba(254,243,199,.3);border-top-color:#fef3c7"></span>
                        <span id="archTxt">📦 Archive Lesson</span>
                    </button>
                </div>
            </form>

        </div>
    </div>

    <script src="../js/lesson.js"></script>
    <script>
        var lessonId = new URLSearchParams(location.search).get('id') || getLessonIdFromUrl();

        fetch('/Lesson/GetLessons')
            .then(function(r) { return r.json(); })
            .then(function(lessons) {
                var l = lessons.find(function(x) { return String(x.id) === String(lessonId); });
                if (!l) return;
                document.getElementById('lpTitle').textContent      = l.title || 'Lesson';
                document.getElementById('lpDesc').textContent       = l.description || '';
                document.getElementById('lpDate').textContent       = '📅 ' + fmtDate(l.createdAt);
                document.getElementById('confirmTitle').textContent = l.title || 'this lesson';
                if (l.lessonSection) {
                    var s = document.getElementById('lpSection');
                    s.textContent   = l.lessonSection;
                    s.style.display = 'inline-block';
                }
            });

        document.getElementById('archiveForm').action = '/Lesson/ArchiveLesson?id=' + lessonId;
    </script>
</body>
</html>
