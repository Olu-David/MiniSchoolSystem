@model MiniSchoolSystem.DTO.EditCourseDTO
@using MiniSchoolSystem.Enums
@{
    ViewData["Title"] = "Edit Course";
    ViewData["Breadcrumb"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section TopBarActions {
    <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
        Back
    </a>
}

<div style="max-width:640px;">
    <form asp-action="EditCourse" asp-route-Id="@Model.Id" method="post" data-loading>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-error" style="margin-bottom:20px;"></div>

        <div class="card fade-in">
            <div class="card-header">
                <div>
                    <div class="card-title">Edit Course</div>
                    <div class="card-subtitle">
                        Last modified:
                        @if (Model.LastModifiedAt.HasValue)
                        {
                            @Model.LastModifiedAt.Value.ToString("MMM d, yyyy 'at' HH:mm")
                        }
                        else
                        {

                            <text>Never</text>
                        }
                    </div>
                </div>
                <div style="width:40px;height:40px;background:#e8f0fe;border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b7dd8" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                </div>
            </div>

            <input type="hidden" asp-for="Id" />

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">Course Title</label>
                    <input asp-for="Title" placeholder="Course title" data-maxlength="100" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SelectedSection">Section</label>
                    <select asp-for="SelectedSection" asp-items="Html.GetEnumSelectList<Sections>()">
                        <option value="">— Select section —</option>
                    </select>
                    <span asp-validation-for="SelectedSection" class="field-validation-error"></span>
                </div>
            </div>

            <div style="margin-top:28px;display:flex;gap:12px;align-items:center;">
                <button type="submit" class="btn btn-primary btn-lg" data-loading-text="Saving…">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                    Save Changes
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancel</a>

                @if (User.IsInRole("SuperAdmin"))
                {
                    <button type="button" class="btn btn-danger btn-sm" style="margin-left:auto;"
                            onclick='confirmAction("Archive this course? Students will no longer see it.", "Archive").then(ok => { if(ok) window.location="/Lesson/ArchiveCourse/@Model.Id"; })'>
                        Archive Course
                    </button>
                }
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
