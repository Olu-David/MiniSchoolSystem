@model MiniSchoolSystem.DTO.CreateCourseViewDTO
@using MiniSchoolSystem.Enums
@{
    ViewData["Title"] = "New Course";
    ViewData["Breadcrumb"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section TopBarActions {
    <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
        Back
    </a>
}

<div style="max-width:640px;">
    <form asp-action="CreateCourse" method="post" data-loading>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-error" style="margin-bottom:20px;"></div>

        <div class="card fade-in">
            <div class="card-header">
                <div>
                    <div class="card-title">Course Details</div>
                    <div class="card-subtitle">Set up the foundation for a new course</div>
                </div>
                <div style="width:40px;height:40px;background:var(--accent-soft);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">Course Title</label>
                    <input asp-for="Title" placeholder="e.g. Mathematics — Form 3" data-maxlength="100" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SelectedSection">Section</label>
                    <select asp-for="SelectedSection" asp-items="Html.GetEnumSelectList<Sections>()">
                        <option value="">— Select section —</option>
                    </select>
                    <span asp-validation-for="SelectedSection" class="field-validation-error"></span>
                    <span class="form-hint">Only sections assigned to you will work.</span>
                </div>
            </div>

            <div style="margin-top:28px;display:flex;gap:12px;">
                <button type="submit" class="btn btn-primary btn-lg" data-loading-text="Creating…">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                    Create Course
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
