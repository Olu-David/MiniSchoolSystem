<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>Restore Lesson — SabiSpace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="../css/lesson.css" />
</head>
<body>

    <div class="page-centered">
        <div class="blob blob-sage blob-tl"></div>
        <div class="blob blob-sky  blob-br" style="opacity:.4"></div>

        <div class="confirm-card border-sage">

            <div class="card-icon sage">♻️</div>
            <h1 class="card-title">Restore this lesson?</h1>
            <p class="card-sub">
                Restoring will make the lesson
                <strong class="sage">visible to students again</strong>
                and cancel the scheduled deletion.
            </p>

            <!-- Lesson preview -->
            <div class="lesson-preview">
                <div class="lesson-preview-label">Lesson to restore</div>
                <div class="lesson-preview-title" id="lpTitle">Loading…</div>
                <div class="lesson-preview-desc" id="lpDesc"></div>
                <div class="lesson-preview-meta">
                    <span id="lpDeleted">—</span>
                    <span class="badge badge-del" id="lpDelBadge" style="display:none">Scheduled for deletion</span>
                </div>
            </div>

            <!-- Days-remaining ring (populated by JS) -->
            <div class="timer-box" id="timerBox" style="display:none">
                <div class="timer-ring">
                    <svg width="52" height="52" viewBox="0 0 52 52">
                        <circle class="ring-bg" cx="26" cy="26" r="22" />
                        <circle class="ring-fill" cx="26" cy="26" r="22" id="ringFill" />
                    </svg>
                    <div class="timer-center">
                        <div class="timer-days" id="timerDays">—</div>
                        <div class="timer-label">days</div>
                    </div>
                </div>
                <div class="timer-info">
                    <p id="timerTitle">—</p>
                    <span id="timerSub">—</span>
                </div>
            </div>

            <!-- What restoring does -->
            <div class="warn-box warn-box-sage">
                <span class="warn-box-icon">♻️</span>
                <div>
                    <p class="warn-box-title">What restoring does</p>
                    <ul class="warn-list">
                        <li>Lesson becomes visible to students immediately</li>
                        <li>All content and files are preserved</li>
                        <li>Scheduled deletion is cancelled permanently</li>
                        <li>Teacher is not notified automatically</li>
                    </ul>
                </div>
            </div>

            <!-- Buttons -->
            <form id="restoreForm" method="post" style="display:contents">
                <!-- @Html.AntiForgeryToken() -->
                <div class="confirm-btns">
                    <a href="/Lesson" class="btn btn-ghost btn-block">← Cancel</a>
                    <button type="submit" class="btn btn-sage btn-block"
                            id="restoreBtn"
                            onclick="showSubmitSpinner('restoreBtn','restSpin','restTxt','Restoring…')">
                        <span class="btn-spin" id="restSpin"></span>
                        <span id="restTxt">♻️ Restore Lesson</span>
                    </button>
                </div>
            </form>

        </div>
    </div>

    <script src="../js/lesson.js"></script>
    <script>
        var lessonId = new URLSearchParams(location.search).get('id') || getLessonIdFromUrl();

        // NOTE: GetLessons only returns active lessons.
        // In the real app, the controller passes ViewBag.Lesson which includes deleted ones.
        // This HTML file uses a separate endpoint if available, or falls back to a placeholder.

        fetch('/Lesson/GetDeletedLessons')   // you may need to add this endpoint
            .then(function(r) { return r.json(); })
            .then(function(lessons) {
                var l = lessons.find(function(x) { return String(x.id) === String(lessonId); });
                if (!l) return;
                populate(l);
            })
            .catch(function() {
                // Fallback — just wire the form
                document.getElementById('restoreForm').action = '/Lesson/RestoreLesson?id=' + lessonId;
            });

        function populate(l) {
            document.getElementById('lpTitle').textContent = l.title || 'Lesson';
            document.getElementById('lpDesc').textContent  = l.description || '';
            document.getElementById('lpDelBadge').style.display = 'inline-flex';

            if (l.deletedAt) {
                document.getElementById('lpDeleted').textContent =
                    '🗑 Deleted: ' + fmtDate(l.deletedAt);

                var daysGone      = (Date.now() - new Date(l.deletedAt).getTime()) / 86400000;
                var daysRemaining = Math.max(0, Math.ceil(30 - daysGone));

                document.getElementById('timerBox').style.display  = 'flex';
                document.getElementById('timerDays').textContent   = daysRemaining;
                document.getElementById('timerTitle').textContent  =
                    daysRemaining + ' day' + (daysRemaining !== 1 ? 's' : '') + ' remaining';

                if (daysRemaining <= 0) {
                    document.getElementById('timerSub').innerHTML =
                        '<span style="color:var(--danger)">Window expired — cannot restore</span>';
                    document.getElementById('restoreBtn').disabled = true;
                } else {
                    var expiry = new Date(new Date(l.deletedAt).getTime() + 30*86400000);
                    document.getElementById('timerSub').textContent =
                        'Window closes ' + fmtDate(expiry.toISOString());
                }

                initTimerRing(daysRemaining, 30);
            }

            document.getElementById('restoreForm').action = '/Lesson/RestoreLesson?id=' + l.id;
        }
    </script>
</body>
</html>
