@{
    ViewData["Title"] = "Lessons — SabiSpace";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
   <link href="~/css/Index.css" rel="stylesheet" />
}

<div class="lp">

    <!-- HERO -->
    <div class="lp-hero">
        <div class="hblob hb1"></div>
        <div class="hblob hb2"></div>
        <div class="hi">
            <div class="hi-left">
                <h1>SabiSpace Lessons</h1>
                <p>Expert-taught, curriculum-aligned lessons for every section and level.</p>
                <div class="badge-row">
                    <span class="hbadge hb-live">Live Now</span>
                    <span class="hbadge hb-info">🎓 12,000+ Learners</span>
                    <span class="hbadge hb-info">📚 340+ Lessons</span>
                </div>
            </div>
            @if (User.IsInRole("Teacher") || User.IsInRole("SuperAdmin"))
            {
                <a asp-controller="Lesson" asp-action="CreateLesson" class="btn btn-sabi">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
                    Create Lesson
                </a>
            }
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="sw">
            <span class="si">⌕</span>
            <input type="search" id="srch" placeholder="Search lessons…" oninput="filter()" />
        </div>
        <select class="fsel" id="secFilter" onchange="filter()">
            <option value="">All Sections</option>
            <option>JSS1</option>
            <option>JSS2</option>
            <option>JSS3</option>
            <option>SS1</option>
            <option>SS2</option>
            <option>SS3</option>
            <option>Higher</option>
            <option>Professional</option>
        </select>
        <div class="vt">
            <button class="vtb on" id="btnG" onclick="setView('g')" title="Grid">⊞</button>
            <button class="vtb" id="btnL" onclick="setView('l')" title="List">☰</button>
        </div>
        <span class="rc" id="rc">Loading…</span>
    </div>

    <!-- GRID -->
    <div class="grid" id="grid">
        <div class="empty" id="loader">
            <div class="empty-icon">⏳</div>
            <h3>Loading lessons…</h3>
            <p>Fetching the latest lessons for you.</p>
        </div>
    </div>

    @if (User.IsInRole("Teacher") || User.IsInRole("SuperAdmin"))
    {
        <a asp-controller="Lesson" asp-action="CreateLesson" class="fab" title="Create lesson">＋</a>
    }

</div>


@section Scripts {
    @* 1. Link to the built-in validation scripts (jQuery Validation) *@
   @* Include standard validation first *@
    <partial name="_ValidationScriptsPartial" />

    @* Link your custom index.js file *@
    <script src="~/js/index.js" asp-append-version="true"></script>

}