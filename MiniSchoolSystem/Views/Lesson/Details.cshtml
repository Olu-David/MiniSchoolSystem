@model MiniSchoolSystem.DTO.CreateLessonViewDTO
@{
    ViewData["Title"] = "Create Lesson";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<link href="/css/Details.css" rel="stylesheet" />
}

<div class="cp">
    <div class="ch">
        <div class="chb1"></div>
        <div class="chb2"></div>
        <div class="chi">
            <div class="bc">
                <a asp-controller="Home" asp-action="Index">Home</a><span class="bcs">›</span>
                <a asp-controller="Lesson" asp-action="Index">Lessons</a><span class="bcs">›</span>
                <span style="color:var(--text-secondary)">Create Lesson</span>
            </div>
            <h1 class="chtitle">Create a New Lesson</h1>
            <p class="chsub">Fill in the details below to publish a lesson for your students.</p>
        </div>
    </div>

    <div class="fw">
        <!-- Steps -->
        <div class="sb">
            <div class="si"><div class="sn act" id="sn1">1</div><span class="sl act" id="sl1">Basic Info</span></div>
            <div class="sline"></div>
            <div class="si"><div class="sn pen" id="sn2">2</div><span class="sl pen" id="sl2">Content</span></div>
            <div class="sline"></div>
            <div class="si"><div class="sn pen" id="sn3">3</div><span class="sl pen" id="sl3">Attachment</span></div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="aerr"><span>⚠️</span><div>@Html.ValidationSummary(false)</div></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="aerr"><span>⚠️</span><span>@TempData["Error"]</span></div>
        }

        <form asp-controller="Lesson" asp-action="CreateLesson" method="post" enctype="multipart/form-data" id="cform">
            @Html.AntiForgeryToken()

            <!-- STEP 1 -->
            <div class="fs act" id="step1">
                <div class="fst">📋 Basic Information</div>
                <div class="fss">Give your lesson a clear title so students know what to expect.</div>
                <div class="fg">
                    <label asp-for="Title">Lesson Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Introduction to Algebra" maxlength="120" oninput="cnt(this,'tc',120)" />
                    <div class="cc" id="tc">0 / 120</div>
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>
                <div class="fg">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" placeholder="What will students learn?" rows="4" maxlength="500" oninput="cnt(this,'dc',500)"></textarea>
                    <div class="cc" id="dc">0 / 500</div>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>
                <div class="row2">
                    <div class="fg">
                        <label asp-for="LessonSection">Section / Level</label>
                        <select asp-for="LessonSection" class="form-control">
                            <option value="" disabled selected>Select section</option>
                            <optgroup label="Junior Secondary">
                                <option value="JSS1">JSS 1</option>
                                <option value="JSS2">JSS 2</option>
                                <option value="JSS3">JSS 3</option>
                            </optgroup>
                            <optgroup label="Senior Secondary">
                                <option value="SS1">SS 1</option>
                                <option value="SS2">SS 2</option>
                                <option value="SS3">SS 3</option>
                            </optgroup>
                            <optgroup label="Tertiary & Professional">
                                <option value="Higher">Higher (University / Poly)</option>
                                <option value="Professional">Professional</option>
                            </optgroup>
                        </select>
                        <span asp-validation-for="LessonSection" class="field-validation-error"></span>
                    </div>
                    <div class="fg">
                        <label asp-for="Id">Lesson ID</label>
                        <input asp-for="Id" class="form-control" type="number" placeholder="e.g. 1001" min="1" />
                        <span asp-validation-for="Id" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="fnav">
                    <a asp-controller="Lesson" asp-action="Index" class="btn btn-ghost">← Cancel</a>
                    <button type="button" class="btn btn-sabi" onclick="go(2)">Next: Add Content →</button>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="fs" id="step2">
                <div class="fst">✏️ Lesson Content</div>
                <div class="fss">Write the main lesson content students will read and learn from.</div>
                <div class="tips">
                    <h5>💡 Writing tips</h5>
                    <ul>
                        <li>Start with a clear learning objective</li>
                        <li>Break content into short readable sections</li>
                        <li>Use examples relevant to the curriculum</li>
                        <li>End with a summary or key takeaways</li>
                    </ul>
                </div>
                <div class="fg">
                    <label for="Content">Content</label>
                    <textarea name="Content" id="Content" class="ced" placeholder="Write your lesson content here…" rows="12" oninput="cnt(this,'ctc',10000)"></textarea>
                    <div class="cc" id="ctc">0 / 10,000</div>
                </div>
                <div class="fnav">
                    <button type="button" class="btn btn-ghost" onclick="go(1)">← Back</button>
                    <button type="button" class="btn btn-sabi" onclick="go(3)">Next: Add Attachment →</button>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="fs" id="step3">
                <div class="fst">📎 Attachment (Optional)</div>
                <div class="fss">Upload a supporting file — PDF, slides, or any resource for students.</div>
                <div class="fdrop" id="fdrop">
                    <input type="file" name="file" id="fi" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.mp4,.zip" onchange="prevFile(this)" />
                    <div class="fdicon">📁</div>
                    <div class="fdtitle">Drag & drop or click to upload</div>
                    <div class="fdsub">PDF, Word, PowerPoint, Excel, MP4, ZIP — max 50MB</div>
                </div>
                <div class="fdprev" id="fdp">
                    <span id="fdi">📎</span>
                    <div><div class="fdname" id="fdn">—</div><div class="fdsize" id="fds">—</div></div>
                    <button type="button" class="fdrm" onclick="rmFile()">✕</button>
                </div>
                <div class="fnav" style="margin-top:32px">
                    <button type="button" class="btn btn-ghost" onclick="go(2)">← Back</button>
                    <button type="submit" class="btn btn-sabi" id="subBtn" onclick="onSubmit()">
                        <span class="spin" id="subSpin"></span>
                        <span id="subTxt">🚀 Publish Lesson</span>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @* 1. Link to the built-in validation scripts (jQuery Validation) *@
    @* Include standard validation first *@
    <partial name="_ValidationScriptsPartial" />

    @* Link your custom index.js file *@
    <script src="~/js/Details.js" asp-append-version="true"></script>
}
