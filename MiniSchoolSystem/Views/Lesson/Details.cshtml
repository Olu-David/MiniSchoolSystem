@{
    ViewData["Title"] = "Lesson Details";
    ViewData["Breadcrumb"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section TopBarActions {
    <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
        All Lessons
    </a>
    @if (User.IsInRole("Teacher") || User.IsInRole("SuperAdmin"))
    {
        <a href="#" class="btn btn-primary btn-sm" id="editLessonBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
            Edit
        </a>
    }
}

<div id="lessonDetail" class="fade-in">
    <!-- Loading skeleton -->
    <div id="loadingSkeleton">
        <div style="display:flex;gap:20px;margin-bottom:24px;flex-wrap:wrap;">
            <div style="flex:1;min-width:280px;" class="card">
                <div style="height:20px;background:#eee;border-radius:4px;margin-bottom:10px;width:40%;"></div>
                <div style="height:32px;background:#eee;border-radius:4px;margin-bottom:8px;"></div>
                <div style="height:16px;background:#f4f4f4;border-radius:4px;width:60%;"></div>
            </div>
        </div>
    </div>

    <!-- Actual content (populated by JS) -->
    <div id="lessonContent" style="display:none;">
        <div style="display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start;" class="detail-layout">

            <!-- Main Content -->
            <div>
                <div class="card" style="margin-bottom:20px;">
                    <div class="card-header">
                        <div>
                            <span class="badge badge-section" id="lessonSectionBadge">—</span>
                            <h2 id="lessonTitle" style="font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;margin-top:8px;letter-spacing:-0.02em;"></h2>
                            <p id="lessonDescription" style="color:var(--text-secondary);font-size:0.9rem;margin-top:6px;line-height:1.6;"></p>
                        </div>
                    </div>
                    <div id="lessonBody" style="font-size:0.9rem;line-height:1.8;color:var(--text-primary);"></div>
                </div>
            </div>

            <!-- Sidebar meta -->
            <div>
                <div class="card" style="margin-bottom:16px;">
                    <div class="card-title" style="margin-bottom:16px;">Details</div>
                    <div style="display:flex;flex-direction:column;gap:12px;font-size:0.85rem;">
                        <div>
                            <div style="color:var(--text-muted);font-size:0.72rem;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:3px;">Created</div>
                            <div id="lessonCreated" style="font-weight:500;">—</div>
                        </div>
                        <div>
                            <div style="color:var(--text-muted);font-size:0.72rem;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:3px;">Status</div>
                            <span class="badge badge-active"><span class="badge-dot"></span>Active</span>
                        </div>
                        <div id="attachmentRow" style="display:none;">
                            <div style="color:var(--text-muted);font-size:0.72rem;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:3px;">Attachment</div>
                            <a id="attachmentLink" href="#" target="_blank" class="btn btn-secondary btn-sm" style="margin-top:4px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" /></svg>
                                Download
                            </a>
                        </div>
                    </div>
                </div>

                @if (User.IsInRole("Teacher") || User.IsInRole("SuperAdmin"))
                {
                    <div class="card">
                        <div class="card-title" style="margin-bottom:14px;">Actions</div>
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <button class="btn btn-secondary btn-sm" id="archiveLessonBtn">Archive Lesson</button>
                            <button class="btn btn-danger btn-sm" id="deleteLessonBtn">Delete Lesson</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <p class="modal-title">Delete this lesson?</p>
        <p class="modal-body">The lesson will be scheduled for deletion. A SuperAdmin can restore it within 30 days.</p>
        <div class="modal-actions">
            <button class="btn btn-secondary" onclick="closeModal('deleteModal')">Cancel</button>
            <button class="btn btn-danger" id="confirmDeleteBtn">Yes, Delete</button>
        </div>
    </div>
</div>

@section Scripts {
  
    <style>
        @@media (max-width: 700px) {
            .detail-layout {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
}
