@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<UserDb> SignInManager
@inject UserManager<UserDb> UserManager

@{
    ViewData["Title"] = "Create Lesson";
    
    if (User.IsInRole("SuperAdmin"))
    {
        Layout = "~/Views/Shared/_SuperAdminSidebar.cshtml";
    }
    Layout = "~/Views/Shared/_Layout.cshtml";


    var userRole = User.FindFirstValue(ClaimTypes.Role);
    var displayName = User.Identity?.Name ?? "User";
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isAllowedRole = User.IsInRole("SuperAdmin")
                      || User.IsInRole("Admin")
                      || User.IsInRole("Teacher")
                      || User.IsInRole("Student");

    bool isBlockedUser = User.Identity!.IsAuthenticated && !isAllowedRole;
    bool isLoggedIn = User.Identity!.IsAuthenticated;
}

@section Styles {
    <link rel="stylesheet" href="~/css/SabiSpace.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Lesson.css" asp-append-version="true" />
}

@if (isBlockedUser)
{
    <div style="padding:40px;text-align:center">
        <h2>Access Restricted</h2>
        <p>Your account doesn't have a recognised role. Contact support.</p>
    </div>
}
else
{
    @if (User.IsInRole("SuperAdmin"))
    {
        @await Html.PartialAsync("_SabiSpaceSidebar")
    }

    <div class="lesson-page">

        <!-- ======================================================
             PAGE HEADER
        ====================================================== -->
        <div class="page-header">
            <div class="blob blob-gold   blob-tl" style="opacity:.7"></div>
            <div class="blob blob-orange blob-br" style="opacity:.4"></div>
            <div class="page-header-inner">
                <div>
                    <div class="breadcrumb">
                        <a asp-controller="Home" asp-action="Index">Home</a><span>›</span>
                        <a asp-controller="Lesson" asp-action="Index">Lessons</a><span>›</span>
                        <span style="color:var(--text-secondary)">Create Lesson</span>
                    </div>
                    <h1 class="page-header-title">Create a New Lesson</h1>
                    <p class="page-header-sub">Fill in the details below to publish a lesson for your students.</p>
                </div>
            </div>
        </div>

        <!-- ======================================================
             FORM
        ====================================================== -->
        <div class="form-wrap">

            <!-- Steps indicator -->
            <div class="steps-bar">
                <div class="step-item">
                    <div class="step-num active" id="sn1">1</div>
                    <span class="step-label active" id="sl1">Basic Info</span>
                </div>
                <div class="step-line"></div>
                <div class="step-item">
                    <div class="step-num pending" id="sn2">2</div>
                    <span class="step-label pending" id="sl2">Content</span>
                </div>
                <div class="step-line"></div>
                <div class="step-item">
                    <div class="step-num pending" id="sn3">3</div>
                    <span class="step-label pending" id="sl3">Attachment</span>
                </div>
            </div>

            <!-- Error alert -->
            <div class="alert-err" id="formAlert" style="display:none">
                <span>⚠️</span><span id="alertMsg">Please fix the errors above.</span>
            </div>

            <form asp-controller="Lesson" asp-action="CreateLesson" id="createForm" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <!-- ============================================
                     STEP 1 — Basic Info
                ============================================ -->
                <div class="form-card active" id="step1" style="display:block">
                    <div class="form-card-header">
                        <div class="form-card-title">📋 Basic Information</div>
                        <span class="form-card-badge">Required</span>
                    </div>

                    <div class="fg">
                        <label for="Title">Lesson Title</label>
                        <input class="field" type="text" id="Title" name="Title"
                               placeholder="e.g. Introduction to Algebra"
                               maxlength="120"
                               oninput="countChars(this,'titleCount',120)" />
                        <div class="char-count" id="titleCount">0 / 120</div>
                        <div class="field-error" id="titleErr">Title is required.</div>
                    </div>

                    <div class="fg">
                        <label for="Description">Description</label>
                        <textarea class="field" id="Description" name="Description"
                              placeholder="What will students learn in this lesson?"
                              rows="4" maxlength="500"
                              oninput="countChars(this,'descCount',500)"></textarea>
                        <div class="char-count" id="descCount">0 / 500</div>
                    </div>

                    <div class="row-2">
                        <div class="fg">
                            <label for="LessonSection">Section / Level</label>
                            <select class="field" id="LessonSection" name="LessonSection">
                                <select name="Section" class="form-control">
                                    <option value="" disabled selected>Select section</option>

                                    <optgroup label="Early Years (Kindergarten)">
                                        <option value="1">Creche</option>
                                        <option value="1">Nursery 1</option>
                                        <option value="1">Nursery 2 / KG</option>
                                    </optgroup>

                                    <optgroup label="Primary School (Elementary)">
                                        <option value="2">Primary 1 - 3</option>
                                        <option value="2">Primary 4 - 6</option>
                                    </optgroup>

                                    <optgroup label="Junior Secondary (Middle)">
                                        <option value="3">JSS 1</option>
                                        <option value="3">JSS 2</option>
                                        <option value="3">JSS 3</option>
                                    </optgroup>

                                    <optgroup label="Senior Secondary (High)">
                                        <option value="4">SS 1</option>
                                        <option value="4">SS 2</option>
                                        <option value="4">SS 3</option>
                                    </optgroup>

                                    <option value="5">University / Higher Education</option>
                                    <option value="6">Professional Training</option>
                                    <option value="7">General / Others</option>
                                </select>
                            </select>
                            <div class="field-error" id="sectionErr">Please select a section.</div>
                        </div>
                        <div class="fg">
                            <label for="Id">Lesson ID</label>
                            <input class="field" type="number" id="Id" name="Id"
                                   placeholder="e.g. 1001" min="1" />
                            <div class="field-error" id="idErr">Lesson ID is required.</div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a asp-controller="Lesson" asp-action="Index" class="btn btn-ghost">← Cancel</a>
                        <button type="button" class="btn btn-sabi" onclick="nextStep1()">
                            Next: Add Content →
                        </button>
                    </div>
                </div>

                <!-- ============================================
                     STEP 2 — Content
                ============================================ -->
                <div class="form-card" id="step2" style="display:none">
                    <div class="form-card-header">
                        <div class="form-card-title">✏️ Lesson Content</div>
                        <span class="form-card-badge">Required</span>
                    </div>

                    <div class="tips-box">
                        <h5>💡 Writing tips</h5>
                        <ul>
                            <li>Start with a clear learning objective</li>
                            <li>Break content into short readable sections</li>
                            <li>Use examples relevant to the curriculum</li>
                            <li>End with a summary or key takeaways</li>
                        </ul>
                    </div>

                    <div class="fg">
                        <label for="Content">Lesson Content</label>
                        <textarea class="field" id="Content" name="Content"
                              placeholder="Write your lesson content here…"
                              rows="14" maxlength="10000"
                              oninput="countChars(this,'contentCount',10000)"
                              style="min-height:260px;line-height:1.8"></textarea>
                        <div class="char-count" id="contentCount">0 / 10,000</div>
                        <div class="field-error" id="contentErr">Please add lesson content.</div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn btn-ghost" onclick="goStep(1)">← Back</button>
                        <button type="button" class="btn btn-sabi" onclick="nextStep2()">
                            Next: Add Attachment →
                        </button>
                    </div>
                </div>

                <!-- ============================================
                     STEP 3 — Attachment
                ============================================ -->
                <div class="form-card" id="step3" style="display:none">
                    <div class="form-card-header">
                        <div class="form-card-title">📎 Attachment</div>
                        <span style="font-size:12px;color:var(--text-dim)">Optional</span>
                    </div>

                    <div class="file-drop" id="fileDrop">
                        <input type="file" id="fileInput" name="file"
                               accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.mp4,.zip"
                               onchange="previewFile(this,'filePreview','dropTitle')" />
                        <div class="file-drop-icon">📁</div>
                        <div class="file-drop-title" id="dropTitle">Drag & drop or click to upload</div>
                        <div class="file-drop-sub">PDF, Word, PowerPoint, Excel, MP4, ZIP — max 50MB</div>
                    </div>

                    <div class="file-preview" id="filePreview">
                        <span data-file-icon>📎</span>
                        <div>
                            <div class="file-preview-name">—</div>
                            <div class="file-preview-size">—</div>
                        </div>
                        <button type="button" class="file-remove"
                                onclick="removeFile('fileInput','filePreview','dropTitle','Drag & drop or click to upload')">
                            ✕
                        </button>
                    </div>

                    <div class="form-actions" style="margin-top:32px">
                        <button type="button" class="btn btn-ghost" onclick="goStep(2)">← Back</button>
                        <button type="submit" class="btn btn-sabi" id="submitBtn" onclick="handleSubmit()">
                            <span class="btn-spin" id="submitSpin"></span>
                            <span id="submitTxt">🚀 Publish Lesson</span>
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>

    @section Scripts {
        <script src="~/js/lesson.js" asp-append-version="true"></script>
        <script>
            // Wire drag-drop
            initDragDrop(document.getElementById('fileDrop'));

            // Step 1 validation
            function nextStep1() {
                var title = document.getElementById('Title').value.trim();
                var section = document.getElementById('LessonSection').value;
                var id = document.getElementById('Id').value;

                toggle('titleErr', !title, 'Title');
                toggle('sectionErr', !section, 'LessonSection');
                toggle('idErr', !id, 'Id');
                if (!title || !section || !id) return;

                goStep(2, null);
                document.getElementById('step1').style.display = 'none';
                document.getElementById('step2').style.display = 'block';
            }

            // Step 2 validation
            function nextStep2() {
                var content = document.getElementById('Content').value.trim();
                toggle('contentErr', !content, 'Content');
                if (!content) return;
                goStep(3, null);
                document.getElementById('step2').style.display = 'none';
                document.getElementById('step3').style.display = 'block';
            }

            // Override goStep to also handle panel visibility
            var _goStep = goStep;
            goStep = function (n) {
                _goStep(n);
                [1, 2, 3].forEach(function (i) {
                    document.getElementById('step' + i).style.display = i === n ? 'block' : 'none';
                });
            };

            function toggle(errId, show, fieldId) {
                var el = document.getElementById(errId);
                var fd = document.getElementById(fieldId);
                if (el) el.classList.toggle('show', show);
                if (fd) fd.classList.toggle('error', show);
            }

            function handleSubmit() {
                showSubmitSpinner('submitBtn', 'submitSpin', 'submitTxt', 'Publishing…');
            }
        </script>
    }
}