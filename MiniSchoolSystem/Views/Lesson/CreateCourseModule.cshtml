@model MiniSchoolSystem.DTO.CreateCourseModulesViewDTO
@using MiniSchoolSystem.Enums
@{
    ViewData["Title"] = "New Module";
    ViewData["Breadcrumb"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section TopBarActions {
    <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
        Back
    </a>
}

<div style="max-width:640px;">
    <form asp-action="CreateCourseModules" method="post" data-loading>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-error" style="margin-bottom:20px;"></div>

        <div class="card fade-in">
            <div class="card-header">
                <div>
                    <div class="card-title">Module Details</div>
                    <div class="card-subtitle">A module groups related lessons inside a course</div>
                </div>
                <div style="width:40px;height:40px;background:#e6f9f0;border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></svg>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Title">Module Title</label>
                    <input asp-for="Title" placeholder="e.g. Week 1: Number Theory" data-maxlength="100" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SelectedSection">Section</label>
                    <select asp-for="SelectedSection" asp-items="Html.GetEnumSelectList<Sections>()">
                        <option value="">— Select section —</option>
                    </select>
                    <span asp-validation-for="SelectedSection" class="field-validation-error"></span>
                </div>

                <div class="form-group full">
                    <label asp-for="CourseId">Parent Course</label>
                    <select asp-for="CourseId">
                        <option value="">— Attach to a course —</option>
                        @if (ViewBag.CourseSelection != null)
                        {
                            foreach (var course in ViewBag.CourseSelection)
                            {
                                <option value="@course.Id">@course.Title</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CourseId" class="field-validation-error"></span>
                    <span class="form-hint">The module will be added under this course.</span>
                </div>
            </div>

            <div style="margin-top:28px;display:flex;gap:12px;">
                <button type="submit" class="btn btn-primary btn-lg" data-loading-text="Creating…">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                    Create Module
                </button>
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
