@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<UserDb> SignInManager
@inject UserManager<UserDb> UserManager

@{

    if (User.IsInRole("SuperAdmin"))
    {
        Layout = "~/Views/Shared/_SuperAdminSidebar.cshtml";
    }
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userRole = User.FindFirstValue(ClaimTypes.Role);
    var displayName = User.Identity?.Name ?? "User";
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isAllowedRole = User.IsInRole("SuperAdmin")
                      || User.IsInRole("Admin")
                      || User.IsInRole("Teacher")
                      || User.IsInRole("Student");

    bool isBlockedUser = User.Identity!.IsAuthenticated && !isAllowedRole;
    bool isLoggedIn = User.Identity!.IsAuthenticated;
}

@section Styles {
    <link rel="stylesheet" href="~/css/SabiSpace.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Lesson.css" asp-append-version="true" />
}

@if (isBlockedUser)
{
    <div style="padding:40px;text-align:center">
        <h2>Access Restricted</h2>
        <p>Your account doesn't have a recognised role. Contact support.</p>
    </div>
}
else
{
    @* render sidebar inside the page when needed (partial must not define sections) *@
    @if (User.IsInRole("SuperAdmin"))
    {
        @await Html.PartialAsync("_SabiSpaceSidebar")
    }

    <div class="lesson-page">

        <!-- PAGE HEADER -->
        <div class="page-header">
            <div class="blob blob-gold blob-tl" style="opacity:.6"></div>
            <div class="blob blob-sky  blob-br" style="opacity:.4"></div>
            <div class="page-header-inner">
                <div>
                    <div class="breadcrumb">
                        <a asp-controller="Home" asp-action="Index">Home</a><span>›</span>
                        <a asp-controller="Lesson" asp-action="Index">Lessons</a><span>›</span>
                        <span style="color:var(--text-secondary)">Edit Lesson</span>
                    </div>
                    <h1 class="page-header-title">Edit Lesson</h1>
                    <p class="page-header-sub">Update the lesson details, content or attachment below.</p>
                    <div class="edit-badge">✏️ Editing: <strong id="editingTitle">Loading…</strong></div>
                </div>
                <div style="display:flex;gap:10px;margin-top:8px;flex-wrap:wrap">
                    <a id="previewBtn" href="#" class="btn btn-ghost btn-sm">👁 Preview</a>
                    <a id="deleteBtn" href="#" class="btn btn-danger btn-sm" style="border-radius:50px">🗑 Delete</a>
                </div>
            </div>
        </div>

        <!-- FORM -->
        <div class="form-wrap">

            <div class="alert-err" id="formAlert" style="display:none">
                <span>⚠️</span><span id="alertMsg"></span>
            </div>

            <form id="editForm" method="post" enctype="multipart/form-data">
                <!-- Action set by JS: /Lesson/EditLesson/{id} -->
                <!-- ============================================
                     CARD 1 — Basic Info
                ============================================ -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-title">📋 Basic Information</div>
                        <span class="form-card-badge">Required</span>
                    </div>

                    <div class="fg">
                        <label for="Title" id="titleLabel">Lesson Title</label>
                        <input class="field" type="text" id="Title" name="Title"
                               placeholder="e.g. Introduction to Algebra"
                               maxlength="120"
                               oninput="countChars(this,'titleCount',120); markChanged(document.getElementById('titleLabel'))" />
                        <div class="char-count" id="titleCount">0 / 120</div>
                        <div class="field-error" id="titleErr">Title is required.</div>
                    </div>

                    <div class="fg">
                        <label for="Description" id="descLabel">Description</label>
                        <textarea class="field" id="Description" name="Description"
                                  placeholder="What will students learn?"
                                  rows="3" maxlength="500"
                                  oninput="countChars(this,'descCount',500); markChanged(document.getElementById('descLabel'))"></textarea>
                        <div class="char-count" id="descCount">0 / 500</div>
                    </div>

                    <div class="row-2">
                        <div class="fg">
                            <label for="LessonSection">Section / Level</label>
                            <select class="field" id="LessonSection" name="LessonSection">
                                <optgroup label="Junior Secondary">
                                    <option value="JSS1">JSS 1</option>
                                    <option value="JSS2">JSS 2</option>
                                    <option value="JSS3">JSS 3</option>
                                </optgroup>
                                <optgroup label="Senior Secondary">
                                    <option value="SS1">SS 1</option>
                                    <option value="SS2">SS 2</option>
                                    <option value="SS3">SS 3</option>
                                </optgroup>
                                <optgroup label="Tertiary & Professional">
                                    <option value="Higher">Higher (University / Poly)</option>
                                    <option value="Professional">Professional</option>
                                </optgroup>
                            </select>
                        </div>
                        <div class="fg">
                            <label>Lesson ID</label>
                            <input class="field" id="IdDisplay" type="number" disabled />
                            <input type="hidden" id="Id" name="Id" />
                        </div>
                    </div>
                </div>

                <!-- ============================================
                     CARD 2 — Content
                ============================================ -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-title">✏️ Lesson Content</div>
                        <span class="form-card-badge">Required</span>
                    </div>
                    <div class="fg">
                        <label for="Content">Content</label>
                        <textarea class="field" id="Content" name="Content"
                                  placeholder="Write lesson content here…"
                                  rows="14" maxlength="10000"
                                  oninput="countChars(this,'contentCount',10000)"
                                  style="min-height:260px;line-height:1.8"></textarea>
                        <div class="char-count" id="contentCount">0 / 10,000</div>
                        <div class="field-error" id="contentErr">Content cannot be empty.</div>
                    </div>
                </div>

                <!-- ============================================
                     CARD 3 — Attachment
                ============================================ -->
                <div class="form-card">
                    <div class="form-card-header">
                        <div class="form-card-title">📎 Attachment</div>
                        <span style="font-size:12px;color:var(--text-dim)">Optional</span>
                    </div>

                    <!-- Existing file (populated by JS) -->
                    <div class="existing-file" id="existingFileWrap" style="display:none">
                        <span class="existing-file-icon">📄</span>
                        <div>
                            <div class="existing-file-name">Current attachment</div>
                            <div class="existing-file-hint">Upload a new file below to replace it</div>
                        </div>
                        <a class="existing-file-view" id="existingFileLink" href="#" target="_blank">↗ View</a>
                    </div>

                    <div class="file-drop" id="fileDrop">
                        <input type="file" id="fileInput" name="file"
                               accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.mp4,.zip"
                               onchange="previewFile(this,'filePreview','dropTitle')" />
                        <div class="file-drop-icon">📁</div>
                        <div class="file-drop-title" id="dropTitle">Upload replacement file</div>
                        <div class="file-drop-sub">PDF, Word, PowerPoint, Excel, MP4, ZIP — max 50MB</div>
                    </div>

                    <div class="file-preview" id="filePreview">
                        <span data-file-icon>📎</span>
                        <div>
                            <div class="file-preview-name">—</div>
                            <div class="file-preview-size">—</div>
                        </div>
                        <button type="button" class="file-remove"
                                onclick="removeFile('fileInput','filePreview','dropTitle','Upload replacement file')">
                            ✕
                        </button>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="form-actions">
                    <a asp-controller="Lesson" asp-action="Index" class="btn btn-ghost">← Cancel</a>
                    <div class="form-actions-right">
                        <a id="deleteBtnBottom" href="#" class="btn btn-danger" style="border-radius:50px">🗑 Delete</a>
                        <button type="submit" class="btn btn-sabi" id="saveBtn">
                            <span class="btn-spin" id="saveSpin"></span>
                            <span id="saveTxt">💾 Save Changes</span>
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>

    @section Scripts {
        <script src="~/js/lesson.js" asp-append-version="true"></script>
        <script>
            var lessonId = getLessonIdFromUrl();

            // Load lesson data and pre-fill form
            fetch('/Lesson/GetLessons')
                .then(function (r) { return r.json(); })
                .then(function (lessons) {
                    var l = lessons.find(function (x) { return String(x.id) === String(lessonId); });
                    if (!l) return;
                    prefill(l);
                });

            function prefill(l) {
                // Wire form action
                document.getElementById('editForm').action = '/Lesson/EditLesson/' + l.id;

                // Header
                document.getElementById('editingTitle').textContent = l.title || '';
                document.title = 'Edit: ' + (l.title || '') + ' — SabiSpace';

                // Fields
                document.getElementById('Title').value = l.title || '';
                document.getElementById('Description').value = l.description || '';
                document.getElementById('Id').value = l.id;
                document.getElementById('IdDisplay').value = l.id;

                // Select section
                var sel = document.getElementById('LessonSection');
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value === l.lessonSection) {
                        sel.selectedIndex = i; break;
                    }
                }

                // Content
                var c = (l.lessonContents || l.lessonContent || [])[0] || {};
                document.getElementById('Content').value = c.content || '';
                countChars(document.getElementById('Content'), 'contentCount', 10000);
                countChars(document.getElementById('Title'), 'titleCount', 120);
                countChars(document.getElementById('Description'), 'descCount', 500);

                // Existing file
                if (c.fileUrl) {
                    document.getElementById('existingFileWrap').style.display = 'flex';
                    document.getElementById('existingFileLink').href = c.fileUrl;
                }

                // Nav buttons
                document.getElementById('previewBtn').href = '/Lesson/Details/' + l.id;
                document.getElementById('deleteBtn').href = '/Lesson/DeleteLesson?id=' + l.id;
                document.getElementById('deleteBtnBottom').href = '/Lesson/DeleteLesson?id=' + l.id;
            }

            initDragDrop(document.getElementById('fileDrop'));
            initUnsavedWarning('editForm', 'saveBtn');

            function handleSave(e) {
                var content = document.getElementById('Content').value.trim();
                if (!content) {
                    e.preventDefault();
                    document.getElementById('contentErr').classList.add('show');
                    document.getElementById('Content').classList.add('error');
                    return;
                }
                showSubmitSpinner('saveBtn', 'saveSpin', 'saveTxt', 'Saving…');
            }
        </script>
    }
}