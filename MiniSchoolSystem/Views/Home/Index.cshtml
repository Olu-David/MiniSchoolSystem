<!-- FEATURES -->
<section class="features-section fade-up">
    <div class="container" style="text-align:center">
        <div class="section-label" style="margin:0 auto 14px">Everything You Need</div>
        <h2 class="section-title" style="text-align:center;max-width:560px;margin:0 auto 12px">One platform. Every tool a learner needs.</h2>
        <p class="section-sub" style="text-align:center;margin:0 auto">From live lessons to quizzes and assignments — SabiSpace has every tool built in.</p>
        <div class="features-grid">
            <div class="feature-card fade-up"><div class="feature-icon fi-sabi">🎓</div><div class="feature-title">Live Lessons</div><div class="feature-body">Watch expert teachers in real time. Pause, rewind and learn at your own pace with fully recorded sessions.</div><span class="feature-tag">340+ teachers</span></div>
            <div class="feature-card fade-up"><div class="feature-icon fi-sky">🧠</div><div class="feature-title">Smart Quizzes</div><div class="feature-body">Test knowledge after every lesson. Multiple choice, fill-in-the-blank and timed quizzes with instant scoring.</div><span class="feature-tag" style="background:rgba(26,124,255,.1);color:var(--sky);border-color:rgba(26,124,255,.2)">Auto-graded</span></div>
            <div class="feature-card fade-up"><div class="feature-icon fi-sage">📝</div><div class="feature-title">Assignments</div><div class="feature-body">Submit written and project-based work. Teachers review, mark and send detailed feedback on the platform.</div><span class="feature-tag" style="background:rgba(61,186,140,.1);color:var(--sage);border-color:rgba(61,186,140,.2)">Teacher feedback</span></div>
            <div class="feature-card fade-up"><div class="feature-icon fi-gold">📚</div><div class="feature-title">Structured Courses</div><div class="feature-body">Follow complete course paths with modules, lessons, quizzes and assignments matching your curriculum.</div><span class="feature-tag" style="background:rgba(245,200,66,.1);color:var(--gold);border-color:rgba(245,200,66,.2)">Curriculum aligned</span></div>
            <div class="feature-card fade-up"><div class="feature-icon fi-purple">🏅</div><div class="feature-title">Certificates</div><div class="feature-body">Earn shareable certificates when you complete a course. Add them to your CV, LinkedIn or portfolio.</div><span class="feature-tag" style="background:rgba(168,85,247,.1);color:#a855f7;border-color:rgba(168,85,247,.2)">Shareable</span></div>
            <div class="feature-card fade-up"><div class="feature-icon fi-pink">📊</div><div class="feature-title">Progress Tracking</div><div class="feature-body">Track quiz scores, assignment grades, lesson completion and overall course progress in real time.</div><span class="feature-tag" style="background:rgba(236,72,153,.1);color:#ec4899;border-color:rgba(236,72,153,.2)">Real-time</span></div>
        </div>
    </div>
</section>

