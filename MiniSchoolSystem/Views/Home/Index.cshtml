@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool loggedIn = ViewBag.IsLoggedIn == true;
    string firstName = loggedIn ? (((string)(ViewBag.UserName ?? "")).Split(' ')[0]) : "";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
}

@if (loggedIn)
{
    <div class="welcome-bar">
        <div class="welcome-left">
            <div class="welcome-av">@(firstName.Length > 0 ? firstName[0].ToString().ToUpper() : "S")</div>
            <div>
                <div class="welcome-name">Welcome back, @ViewBag.UserName! 👋</div>
                <div class="welcome-sub">@(string.IsNullOrEmpty(ViewBag.UserSection as string) ? "Ready to continue learning?" : ViewBag.UserSection + " · Ready to continue learning?")</div>
            </div>
        </div>
        <div class="welcome-right">
            <a asp-controller="Lesson" asp-action="Index" class="wb-btn wb-primary">Continue Learning →</a>
            <a asp-controller="Quiz" asp-action="Index" class="wb-btn wb-ghost">Take a Quiz</a>
            <a asp-controller="Assignment" asp-action="Index" class="wb-btn wb-ghost">Assignments</a>
        </div>
    </div>
}

<!-- HERO -->
<section class="hero">
    <div class="hero-dot-grid"></div>
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-blob hero-blob-3"></div>
    <div class="hero-inner">
        <div>
            <div class="hero-badge"><span class="hbdot"></span> Africa's #1 Learning Platform</div>
            @if (loggedIn)
            {
                <h1 class="hero-title">Keep Going,<br><em>@firstName</em>.<br>You're Crushing It.</h1>
                <p class="hero-sub">Pick up where you left off, tackle a new quiz, or submit your next assignment. Your progress is waiting.</p>
                <div class="hero-actions">
                    <a asp-controller="Lesson" asp-action="Index" class="btn btn-sabi" style="border-radius:50px;padding:12px 28px;font-size:15px">Continue Learning →</a>
                    <a asp-controller="Quiz" asp-action="Index" class="btn btn-ghost" style="border-radius:50px;padding:12px 28px;font-size:15px">Take a Quiz</a>
                </div>
            }
            else
            {
                <h1 class="hero-title">Learn Smarter.<br>Grow <em>Faster</em>.<br>With SabiSpace.</h1>
                <p class="hero-sub">Live lessons, quizzes, assignments and expert teachers — curriculum-aligned from JSS to Professional level. Learn on your terms.</p>
                <div class="hero-actions">
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-sabi" style="border-radius:50px;padding:12px 28px;font-size:15px">Start Learning Free →</a>
                    <a href="#how-it-works" class="btn btn-ghost" style="border-radius:50px;padding:12px 28px;font-size:15px">See How It Works ↓</a>
                </div>
            }
            <div class="hero-stats">
                <div><div class="stat-num">12K<span>+</span></div><div class="stat-lbl">Active Learners</div></div>
                <div><div class="stat-num">340<span>+</span></div><div class="stat-lbl">Expert Teachers</div></div>
                <div><div class="stat-num">1.2K<span>+</span></div><div class="stat-lbl">Lessons &amp; Quizzes</div></div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="float-badge fb1">🎯 67% avg quiz score this week</div>
            <div class="hero-card">
                <div class="hero-card-header">
                    <div class="hero-card-av">S</div>
                    <div>
                        <div class="hero-card-title">SabiSpace Web Dev</div>
                        <div class="hero-card-sub">Module 3 · ASP.NET MVC</div>
                    </div>
                    <div class="live-pill">LIVE</div>
                </div>
                <p class="progress-lbl">Your Progress — 67% Complete</p>
                <div class="prog-bar"><div class="prog-fill"></div></div>
                <div class="fp-row">
                    <span class="fp on">HTML &amp; CSS</span>
                    <span class="fp on">C# Basics</span>
                    <span class="fp on">MVC</span>
                    <span class="fp">Auth</span>
                    <span class="fp">Quiz</span>
                    <span class="fp">Deploy</span>
                </div>
            </div>
            <div class="float-badge fb2">🏅 Certificates earned · 1.2K this week</div>
        </div>
    </div>
</section>

