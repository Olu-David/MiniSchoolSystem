@if (!loggedIn)
{
    <!-- ══════════════════════════════════════════
         FAQ — guest only
    ══════════════════════════════════════════ -->
    <section class="faq-section fade-up">
        <div class="container">
            <div style="text-align:center">
                <div class="section-label" style="margin:0 auto 14px">Got Questions?</div>
                <h2 class="section-title" style="text-align:center;max-width:400px;margin:0 auto 12px">Frequently Asked Questions</h2>
                <p class="section-sub" style="text-align:center;margin:0 auto 0">Everything first-time visitors want to know.</p>
            </div>
            <div class="faq-list">
                <div class="faq-item">
                    <button class="faq-q" onclick="toggleFaq(this)">
                        Is SabiSpace really free to join?
                        <span class="faq-arrow">+</span>
                    </button>
                    <div class="faq-a"><p>Yes — creating an account is completely free. No credit card, no hidden fees. Sign up and start learning straight away.</p></div>
                </div>
                <div class="faq-item">
                    <button class="faq-q" onclick="toggleFaq(this)">
                        What level is the content aimed at?
                        <span class="faq-arrow">+</span>
                    </button>
                    <div class="faq-a"><p>SabiSpace covers JSS 1–3, SS 1–3, Higher Education and Professional level. When you sign up you choose your level and we show the most relevant content first.</p></div>
                </div>
                <div class="faq-item">
                    <button class="faq-q" onclick="toggleFaq(this)">
                        How do quizzes and assignments work?
                        <span class="faq-arrow">+</span>
                    </button>
                    <div class="faq-a"><p>After each lesson you can take a matching quiz — results and explanations are instant. Assignments are submitted through the platform and your teacher reviews and sends written feedback within 48 hours.</p></div>
                </div>
                <div class="faq-item">
                    <button class="faq-q" onclick="toggleFaq(this)">
                        Will I get a certificate?
                        <span class="faq-arrow">+</span>
                    </button>
                    <div class="faq-a"><p>Yes. Complete all lessons, quizzes and assignments in a course and you'll earn a shareable certificate you can download and add to your CV or LinkedIn profile.</p></div>
                </div>
                <div class="faq-item">
                    <button class="faq-q" onclick="toggleFaq(this)">
                        Can I use SabiSpace on my phone?
                        <span class="faq-arrow">+</span>
                    </button>
                    <div class="faq-a"><p>Absolutely. SabiSpace is fully responsive and works on any device — phone, tablet or desktop. Learn from wherever you are.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- FINAL CTA -->
    <div class="cta-banner fade-up">
        <div class="cta-inner">
            <h2>Ready to join <span>12,000+</span> learners on SabiSpace?</h2>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-white">Create Free Account →</a>
        </div>
    </div>
}

@section Scripts {
    <script>
        function toggleFaq(btn) {
            var item = btn.closest('.faq-item');
            var isOpen = item.classList.contains('open');
            // close all
            document.querySelectorAll('.faq-item.open').forEach(function(el){ el.classList.remove('open'); });
            // open clicked if it wasn't open
            if (!isOpen) item.classList.add('open');
        }
    </script>
}
