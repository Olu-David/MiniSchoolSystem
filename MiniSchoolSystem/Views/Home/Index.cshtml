<!-- QUIZ + ASSIGNMENT PROMO -->
<section class="promo-section fade-up" id="features">
    <div class="container">
        <div class="promo-inner">
            <div class="promo-card promo-card-quiz">
                <div class="promo-icon">🧠</div>
                <h3 class="promo-title">Test Yourself with Smart Quizzes</h3>
                <p class="promo-body">Every lesson has a matching quiz. Get instant results, see what you got wrong and understand why — powered by teacher-written explanations.</p>
                <div class="promo-stats">
                    <div class="promo-stat"><div class="promo-stat-num">800+</div><div class="promo-stat-lbl">Quizzes</div></div>
                    <div class="promo-stat"><div class="promo-stat-num">4.8★</div><div class="promo-stat-lbl">Avg rating</div></div>
                    <div class="promo-stat"><div class="promo-stat-num">Instant</div><div class="promo-stat-lbl">Results</div></div>
                </div>
                <a asp-controller="Quiz" asp-action="Index" class="btn btn-quiz">Browse Quizzes →</a>
            </div>
            <div class="promo-card promo-card-assign">
                <div class="promo-icon">📝</div>
                <h3 class="promo-title">Submit Assignments &amp; Get Real Feedback</h3>
                <p class="promo-body">Write essays, solve problems and build projects. Your teacher reviews every submission and sends personal written feedback.</p>
                <div class="promo-stats">
                    <div class="promo-stat"><div class="promo-stat-num">500+</div><div class="promo-stat-lbl">Assignments</div></div>
                    <div class="promo-stat"><div class="promo-stat-num">48h</div><div class="promo-stat-lbl">Avg feedback</div></div>
                    <div class="promo-stat"><div class="promo-stat-num">100%</div><div class="promo-stat-lbl">Personal review</div></div>
                </div>
                <a asp-controller="Assignment" asp-action="Index" class="btn btn-assign">View Assignments →</a>
            </div>
        </div>
    </div>
</section>

