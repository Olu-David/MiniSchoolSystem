@model MiniSchoolSystem.DTO.LoginViewDTO
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Auth.css" asp-append-version="true" />
}

<div class="auth-wrap">

    <!-- ══════════════ LEFT PANEL ══════════════ -->
    <div class="auth-left">
        <div class="blob b1"></div>
        <div class="blob b2"></div>
        <div class="blob b3"></div>

        <div class="left-inner">
            <a asp-controller="Home" asp-action="Index" class="logo">
                <div class="logo-mark">S</div>
                <span class="logo-text">Sabi<span>Space</span></span>
            </a>

            <h1 class="left-headline">
                Welcome<br>back to<br><em>SabiSpace</em>.
            </h1>
            <p class="left-sub">
                Your lessons, quizzes and assignments are waiting.<br>
                Sign in and keep the momentum going.
            </p>

            <div class="card-list">
                <div class="info-card">
                    <div class="card-icon ci-o">🎓</div>
                    <div>
                        <div class="card-stat">1,200+</div>
                        <div class="card-label">Lessons &amp; Quizzes</div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="card-icon ci-s">🌍</div>
                    <div>
                        <div class="card-stat">12,000+</div>
                        <div class="card-label">Active Learners</div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="card-icon ci-g">🏅</div>
                    <div>
                        <div class="card-stat">340+</div>
                        <div class="card-label">Expert Teachers</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════ RIGHT PANEL ══════════════ -->
    <div class="auth-right">
        <div class="form-shell">

            <h2 class="panel-title">Sign In</h2>
            <p class="panel-sub">
                Don't have an account?
                <a asp-controller="Account" asp-action="Registration">Create one free →</a>
            </p>

            <!-- Social sign-in -->
            <div class="social-row">
                <a href="#" class="soc-btn" onclick="SabiToast('Google sign-in coming soon','info');return false">
                    <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" /><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" /><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
                    Google
                </a>
                <button type="button" class="soc-btn apple" onclick="SabiToast('Apple sign-in coming soon','info')">
                    <svg width="15" height="15" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-37.3-155.5-127.4C46.7 790.7 0 663 0 541.8c0-207.5 130.4-317.9 258.3-317.9 33.7 0 67.4 11.8 98.3 24.5 29.5 12 63.5 24.5 95.3 24.5 28.2 0 62.2-11.8 93.9-24.5 35.8-13.7 72.5-26.2 111.5-26.2 2.9 0 5.8.2 8.6.3z" /><path d="M505.7 36.8c-9.7-25.4-22.5-52.7-44.9-73.1-22.2-20.3-48.4-37.8-75.6-37.8-1.6 0-3.1.1-4.7.2-1.5 19.5 4.3 39.8 13.7 56.3 10.8 18.9 25.1 34.7 40.9 46.1 16.6 11.9 36.3 20.3 55.6 23.6 4.5.8 9 1.2 13.5 1.2.2-5.6-.6-11.1-2-16.5z" /></svg>
                    Apple
                </button>
                <button type="button" class="soc-btn yahoo" onclick="SabiToast('Yahoo sign-in coming soon','info')">
                    <svg width="14" height="14" viewBox="0 0 32 32" fill="currentColor"><path d="M18 21.5L13 32H7l5-10.5L0 0h6.5l7.5 15.5L21.5 0H28z" /><path d="M25 15a7 7 0 100 14 7 7 0 000-14zm0 10.5a3.5 3.5 0 110-7 3.5 3.5 0 010 7z" /></svg>
                    Yahoo
                </button>
            </div>

            <div class="or-div">or continue with email</div>

            <!-- Validation errors -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-err">
                    <span>⚠️</span>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <!-- Login form -->
            <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
                @Html.AntiForgeryToken()

                <div class="fg">
                    <label asp-for="Email">Email address</label>
                    <input asp-for="Email"
                           class="form-control"
                           type="email"
                           placeholder="you@example.com"
                           autocomplete="email"
                           autofocus />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="fg">
                    <label asp-for="Password">Password</label>
                    <div class="pw-wrap">
                        <input asp-for="Password"
                               class="form-control"
                               type="password"
                               id="pw"
                               placeholder="Your password"
                               autocomplete="current-password" />
                        <button type="button" class="pw-eye" onclick="toggleEye('pw',this)" aria-label="Toggle password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot">
                        Forgot password?
                    </a>
                </div>

                <div class="fg">
                    <div class="check-row">
                        <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                        <label asp-for="RememberMe">Keep me signed in</label>
                    </div>
                </div>

                <button type="submit" class="submit-btn" id="loginBtn">
                    <span class="spin" id="loginSpin"></span>
                    <span id="loginTxt">Sign In →</span>
                </button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/Auth.js" asp-append-version="true"></script>
}
