@{
    ViewData["Title"] = "Account Confirmed — SabiSpace";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        :root {
            --sabi: #ff5c1a;
            --sabi-h: #ff7340;
            --sabi-dim: rgba(255,92,26,.14);
            --sabi-ring: rgba(255,92,26,.24);
            --sage: #3dba8c;
            --gold: #f5c842;
            --ink: #0b0c0f;
            --ink2: #13151c;
            --ink3: #1a1d27;
            --text-primary: #f0ede8;
            --text-secondary: #a09a93;
            --text-dim: #5c5650;
            --border: rgba(255,255,255,.07);
            --border2: rgba(255,255,255,.13);
        }

        .ac-page {
            min-height: calc(100vh - 60px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            background: var(--ink);
            position: relative;
            overflow: hidden;
        }

            .ac-page::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(circle,rgba(255,255,255,.04) 1px,transparent 1px);
                background-size: 28px 28px;
                pointer-events: none;
            }

        /* blobs */
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none
        }

        .b1 {
            width: 600px;
            height: 600px;
            background: rgba(61,186,140,.14);
            top: -180px;
            left: -160px;
            animation: d1 14s ease-in-out infinite alternate
        }

        .b2 {
            width: 440px;
            height: 440px;
            background: rgba(255,92,26,.1);
            bottom: -130px;
            right: -130px;
            animation: d2 10s ease-in-out infinite alternate
        }

        .b3 {
            width: 300px;
            height: 300px;
            background: rgba(245,200,66,.07);
            top: 40%;
            left: 50%;
            animation: d3 8s ease-in-out infinite alternate
        }

        @@keyframes d1 {
            to {
                transform: translate(24px,16px) scale(1.06)
            }
        }

        @@keyframes d2 {
            to {
                transform: translate(-16px,24px) scale(1.08)
            }
        }

        @@keyframes d3 {
            to {
                transform: translate(-50%,-50%) scale(1.18)
            }
        }

        /* card */
        .ac-card {
            position: relative;
            z-index: 1;
            background: rgba(19,21,28,.78);
            backdrop-filter: blur(28px) saturate(160%);
            -webkit-backdrop-filter: blur(28px) saturate(160%);
            border: 1px solid rgba(255,255,255,.09);
            border-radius: 28px;
            padding: 60px 52px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 32px 80px rgba(0,0,0,.55);
            text-align: center;
        }

        /* ── Animated tick ── */
        .ac-tick-wrap {
            width: 96px;
            height: 96px;
            margin: 0 auto 32px;
            position: relative;
        }

        .ac-tick-circle {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: rgba(61,186,140,.12);
            border: 2px solid rgba(61,186,140,.3);
            display: grid;
            place-items: center;
            animation: tick-pop .5s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes tick-pop {
            0% {
                transform: scale(0);
                opacity: 0
            }

            70% {
                transform: scale(1.1)
            }

            100% {
                transform: scale(1);
                opacity: 1
            }
        }

        .ac-tick-circle svg {
            animation: tick-draw .6s .3s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes tick-draw {
            0% {
                opacity: 0;
                transform: scale(.5) rotate(-20deg)
            }

            100% {
                opacity: 1;
                transform: scale(1) rotate(0)
            }
        }
        /* Pulsing glow ring */
        .ac-tick-wrap::after {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            border: 2px solid rgba(61,186,140,.2);
            animation: glow 2.5s ease-in-out infinite;
        }

        @@keyframes glow {
            0%, 100% {
                opacity: 0;
                transform: scale(1)
            }

            50% {
                opacity: 1;
                transform: scale(1.08)
            }
        }

        /* badge */
        .ac-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 16px;
            border-radius: 50px;
            background: rgba(61,186,140,.12);
            border: 1px solid rgba(61,186,140,.28);
            font-size: 11.5px;
            font-weight: 700;
            color: var(--sage);
            letter-spacing: .5px;
            text-transform: uppercase;
            margin-bottom: 22px;
            animation: badge-in .5s .6s both;
        }

        @@keyframes badge-in {
            from {
                opacity: 0;
                transform: translateY(8px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .bd {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--sage);
            animation: blink .8s ease-in-out infinite alternate
        }

        @@keyframes blink {
            from {
                opacity: .3
            }

            to {
                opacity: 1
            }
        }

        /* title */
        .ac-title {
            font-family: 'Syne',sans-serif;
            font-weight: 800;
            font-size: 2rem;
            letter-spacing: -.7px;
            color: var(--text-primary);
            line-height: 1.15;
            margin-bottom: 14px;
            animation: fade-up .5s .5s both;
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(12px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        /* body */
        .ac-body {
            font-size: 15px;
            color: var(--text-secondary);
            line-height: 1.8;
            margin-bottom: 36px;
            animation: fade-up .5s .65s both;
        }

            .ac-body strong {
                color: var(--text-primary);
                font-weight: 600
            }

        /* perks */
        .ac-perks {
            display: flex;
            flex-direction: column;
            gap: 9px;
            margin-bottom: 40px;
            text-align: left;
            animation: fade-up .5s .75s both;
        }

        .ac-perk {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: rgba(61,186,140,.06);
            border: 1px solid rgba(61,186,140,.12);
            border-radius: 13px;
            font-size: 13.5px;
            color: var(--text-secondary);
            transition: background .2s,border-color .2s;
        }

            .ac-perk:hover {
                background: rgba(61,186,140,.1);
                border-color: rgba(61,186,140,.22)
            }

        .perk-check {
            width: 26px;
            height: 26px;
            border-radius: 8px;
            flex-shrink: 0;
            background: rgba(61,186,140,.18);
            border: 1px solid rgba(61,186,140,.3);
            display: grid;
            place-items: center;
            font-size: 12px;
            color: var(--sage);
            font-weight: 800;
        }

        /* countdown */
        .ac-countdown {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            color: var(--text-dim);
            margin-bottom: 16px;
            animation: fade-up .5s .85s both;
        }

        .cd-ring {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,.1);
            border-top-color: var(--sabi);
            animation: spin .8s linear infinite;
            flex-shrink: 0;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }

        #cd-num {
            font-weight: 700;
            color: var(--sabi);
            min-width: 14px;
            text-align: center;
        }

        /* CTA button */
        .ac-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 15px;
            border-radius: 14px;
            background: var(--sabi);
            border: none;
            color: #fff;
            font-family: 'DM Sans',sans-serif;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 6px 24px rgba(255,92,26,.35);
            transition: background .2s,box-shadow .2s,transform .2s;
            animation: fade-up .5s .9s both;
        }

            .ac-btn:hover {
                background: var(--sabi-h);
                box-shadow: 0 8px 32px rgba(255,92,26,.5);
                transform: translateY(-2px);
                color: #fff
            }

            .ac-btn svg {
                transition: transform .2s
            }

            .ac-btn:hover svg {
                transform: translateX(4px)
            }

        @@media(max-width:480px) {
            .ac-card {
                padding: 44px 28px
            }

            .ac-title {
                font-size: 1.7rem
            }
        }
    </style>
}

<div class="ac-page">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>

    <div class="ac-card">

        <!-- Animated tick -->
        <div class="ac-tick-wrap">
            <div class="ac-tick-circle">
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
                    <path d="M10 22L18 30L34 14"
                          stroke="#3dba8c" stroke-width="3.5"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
        </div>

        <!-- Badge -->
        <div class="ac-badge"><span class="bd"></span> Account Verified</div>

        <!-- Title -->
        <h1 class="ac-title">Your account has been<br>confirmed! 🎉</h1>

        <!-- Body -->
        <p class="ac-body">
            Welcome to <strong>SabiSpace</strong>. Your email has been verified and your account is now fully active. You're ready to start learning.
        </p>

        <!-- What's unlocked -->
        <div class="ac-perks">
            <div class="ac-perk">
                <div class="perk-check">✓</div>
                <span>Full access to all SabiSpace lessons &amp; courses</span>
            </div>
            <div class="ac-perk">
                <div class="perk-check">✓</div>
                <span>Progress tracking across all your subjects</span>
            </div>
            <div class="ac-perk">
                <div class="perk-check">✓</div>
                <span>Certificates on course completion</span>
            </div>
        </div>

        <!-- Countdown -->
        <p class="ac-countdown">
            <span class="cd-ring"></span>
            Redirecting to sign in in <span id="cd-num">5</span>s
        </p>

        <!-- Login link -->
        <a asp-controller="Account" asp-action="Login" class="ac-btn" id="loginBtn">
            Sign In to SabiSpace
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
        </a>

    </div>
</div>

@section Scripts {
    <script>
        /* Auto-redirect countdown */
        var secs = 5;
        var el   = document.getElementById('cd-num');
        var btn  = document.getElementById('loginBtn');
        var loginUrl = '@Url.Action("Login", "Auth")';

        var t = setInterval(function () {
            secs--;
            el.textContent = secs;
            if (secs <= 0) {
                clearInterval(t);
                window.location.href = loginUrl;
            }
        }, 1000);

        /* Cancel auto-redirect if user clicks the button themselves */
        btn.addEventListener('click', function () {
            clearInterval(t);
        });
    </script>
}
