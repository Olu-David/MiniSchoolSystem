@model MiniSchoolSystem.DTO.RegisterViewModel
<!DOCTYPE html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration— SabiSpace</title>


    <link href="~/css/Registration.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-wrap">

        <!-- ══ LEFT ══ -->
        <aside class="auth-left">
            <div class="blob b1"></div>
            <div class="blob b2"></div>
            <div class="blob b3"></div>
            <div class="left-inner">
                <a href="/" class="logo">
                    <div class="logo-mark">S</div>
                    <span class="logo-text">Sabi<span>Space</span></span>
                </a>
                <h2 class="left-headline">Join 12,000+<br><em>SabiSpace</em> Learners.</h2>
                <p class="left-sub">Set up your account in under 2 minutes and start learning today.</p>
                <div class="card-list">
                    <div class="info-card">
                        <div class="step-num">1</div>
                        <div><div class="step-p">Create your account</div><div class="step-s">Fill in your details below</div></div>
                    </div>
                    <div class="info-card">
                        <div class="step-num">2</div>
                        <div><div class="step-p">Confirm your email</div><div class="step-s">Check your inbox for a link</div></div>
                    </div>
                    <div class="info-card">
                        <div class="step-num">3</div>
                        <div><div class="step-p">Start learning</div><div class="step-s">Access all lessons instantly</div></div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- ══ RIGHT ══ -->
        <main class="auth-right">
            <div class="form-shell">

                <h1 class="panel-title">Create your account 🎉</h1>
                <p class="panel-sub">
                    Already registered?
                    <a asp-controller="Auth" asp-action="Login">Sign in →</a>
                </p>

                <!-- Social auth -->
                <div class="social-row">
                    <a asp-controller="Auth" asp-action="GoogleLogin" class="soc-btn">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                            <path d="M17.64 9.2a10.34 10.34 0 00-.16-1.84H9v3.48h4.84a4.14 4.14 0 01-1.8 2.72v2.26h2.92C16.66 14.23 17.64 11.93 17.64 9.2z" fill="#4285F4" />
                            <path d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26a5.4 5.4 0 01-8.07-2.85H.96v2.33A9 9 0 009 18z" fill="#34A853" />
                            <path d="M3.97 10.71A5.41 5.41 0 013.7 9c0-.59.1-1.17.27-1.71V4.96H.96a9 9 0 000 8.08l3.01-2.33z" fill="#FBBC05" />
                            <path d="M9 3.58a4.86 4.86 0 013.44 1.35l2.58-2.58A8.67 8.67 0 009 0 9 9 0 00.96 4.96L3.97 7.3A5.36 5.36 0 019 3.58z" fill="#EA4335" />
                        </svg>
                        Google
                    </a>
                    <a asp-controller="Auth" asp-action="AppleLogin" class="soc-btn apple">
                        <svg width="15" height="18" viewBox="0 0 15 18" fill="currentColor">
                            <path d="M12.77 9.23c-.02-2.1 1.72-3.12 1.8-3.17-1-1.44-2.5-1.64-3.04-1.66-1.3-.13-2.53.76-3.19.76-.66 0-1.68-.74-2.76-.72-1.42.02-2.73.83-3.46 2.1-1.48 2.56-.38 6.35 1.06 8.43.7 1.02 1.54 2.16 2.64 2.12 1.06-.04 1.46-.68 2.74-.68 1.27 0 1.64.68 2.75.66 1.14-.02 1.86-1.03 2.56-2.06a9.98 9.98 0 001.16-2.38c-.03-.01-2.23-.86-2.26-3.4zM10.64 2.63A4.17 4.17 0 0011.68.5a4.23 4.23 0 00-2.73 1.41A3.96 3.96 0 008 4.78c1.08.08 2.18-.55 2.64-2.15z" />
                        </svg>
                        Apple
                    </a>
                    <a asp-controller="Auth" asp-action="YahooLogin" class="soc-btn yahoo">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M0 0h10.3L12 3.6 13.7 0H24L15.6 12.8V24H8.4V12.8z" />
                        </svg>
                        Yahoo
                    </a>
                </div>

                <div class="or-div">or register with email</div>

                <!-- Server errors -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-err">
                        <span>⚠️</span>
                        <span>@Html.ValidationSummary(false)</span>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert-err">
                        <span>⚠️</span>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <!-- Register form -->
                <form asp-controller="Auth" asp-action="Register" method="post" id="regForm">
                    @Html.AntiForgeryToken()

                    <div class="row2">
                        <div class="fg">
                            <label asp-for="FirstName">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Chidi" autocomplete="given-name" />
                            <span asp-validation-for="FirstName" class="field-validation-error"></span>
                        </div>
                        <div class="fg">
                            <label asp-for="LastName">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Okafor" autocomplete="family-name" />
                            <span asp-validation-for="LastName" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="fg">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" class="form-control" type="email"
                               placeholder="you@example.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div class="fg">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" type="tel"
                               placeholder="+234 800 000 0000" autocomplete="tel" />
                        <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                    </div>

                    <!-- Role toggle — Student / Parent -->
                    <div class="fg">
                        <label>I am a</label>
                        <div class="role-toggle">
                            <button type="button" class="role-btn on" id="btnStudent" onclick="selectRole('Student')">
                                🎒 Student
                            </button>
                            <button type="button" class="role-btn" id="btnParent" onclick="selectRole('Parent')">
                                👨‍👩‍👦 Parent
                            </button>
                        </div>
                        <input type="hidden" asp-for="Role" id="roleInput" value="Student" />
                        <span asp-validation-for="Role" class="field-validation-error"></span>
                    </div>

                    <!-- Section — shown only for Student -->
                    <div class="fg section-group show" id="sectionGroup">
                        <label asp-for="Section">Section / Level</label>
                        <select asp-for="Section" class="form-control" id="sectionSelect">
                            <option value="" disabled selected>Select your level</option>
                            <optgroup label="Junior Secondary">
                                <option value="JSS1">JSS 1</option>
                                <option value="JSS2">JSS 2</option>
                                <option value="JSS3">JSS 3</option>
                            </optgroup>
                            <optgroup label="Senior Secondary">
                                <option value="SS1">SS 1</option>
                                <option value="SS2">SS 2</option>
                                <option value="SS3">SS 3</option>
                            </optgroup>
                            <optgroup label="Tertiary & Professional">
                                <option value="Higher">Higher (University / Poly)</option>
                                <option value="Professional">Professional</option>
                            </optgroup>
                        </select>
                        <span asp-validation-for="Section" class="field-validation-error"></span>
                    </div>

                    <!-- Password -->
                    <div class="fg">
                        <label asp-for="Password">Password</label>
                        <div class="pw-wrap">
                            <input asp-for="Password" class="form-control" type="password"
                                   id="regPw" placeholder="Min. 8 characters"
                                   oninput="measureStrength(this.value)"
                                   autocomplete="new-password" />
                            <button type="button" class="pw-eye" onclick="toggleEye('regPw',this)" aria-label="Show password">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </button>
                        </div>
                        <div class="sw" id="sw">
                            <div class="sw-bars">
                                <div class="sw-bar" id="sb1"></div>
                                <div class="sw-bar" id="sb2"></div>
                                <div class="sw-bar" id="sb3"></div>
                                <div class="sw-bar" id="sb4"></div>
                            </div>
                            <div class="sw-label" id="sl"></div>
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <!-- Terms -->
                    <div class="fg" style="margin-top:4px">
                        <div class="check-row">
                            <input type="checkbox" id="terms" name="agreeTerms" value="true" />
                            <label for="terms">
                                I agree to SabiSpace's
                                <a href="/terms" target="_blank">Terms of Service</a> and
                                <a href="/privacy" target="_blank">Privacy Policy</a>
                            </label>
                        </div>
                        <span class="field-validation-error" id="termsErr" style="display:none">
                            You must agree to continue.
                        </span>
                    </div>

                    <button type="submit" class="submit-btn" id="regBtn">
                        <span class="spin" id="regSpin"></span>
                        <span id="regTxt">Create My Account →</span>
                    </button>
                </form>

            </div>
        </main>
    </div>
    <script src="~/js/Login.js"></script>
</body>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    }


}