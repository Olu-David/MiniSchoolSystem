    @RenderSection("Scripts", required: false)

    <script>
        /* ── Progress bar ── */
        (function () {
            const bar = document.getElementById('progressBar');
            let w = 0;
            const iv = setInterval(() => {
                w = Math.min(w + Math.random() * 18, 85);
                bar.style.width = w + '%';
            }, 120);
            window.addEventListener('load', () => {
                clearInterval(iv);
                bar.style.width = '100%';
                setTimeout(() => { bar.style.opacity = '0'; }, 400);
            });
        })();

        /* ── Nav scroll effect ── */
        window.addEventListener('scroll', () => {
            document.getElementById('mainNav').classList.toggle('scrolled', scrollY > 20);
        }, { passive: true });

        /* ── Mobile drawer ── */
        function toggleDrawer() {
            const drawer = document.getElementById('navDrawer');
            const burger = document.getElementById('burger');
            const open   = drawer.classList.toggle('open');
            burger.classList.toggle('open', open);
            document.body.style.overflow = open ? 'hidden' : '';
        }
        // Close on backdrop click
        document.getElementById('navDrawer').addEventListener('click', function (e) {
            if (e.target === this) toggleDrawer();
        });

        /* ── Announcement bar ── */
        function dismissAnnounce() {
            const bar = document.getElementById('announceBar');
            bar.style.transition = 'opacity .3s, max-height .4s';
            bar.style.opacity = '0';
            bar.style.maxHeight = '0';
            bar.style.padding = '0';
            bar.style.overflow = 'hidden';
            sessionStorage.setItem('sabi-announce-dismissed', '1');
        }
        if (sessionStorage.getItem('sabi-announce-dismissed')) dismissAnnounce();

        /* ── Global toast ── */
        window.SabiToast = function (msg, type, duration, title) {
            type     = type     || 'info';
            duration = duration || 4500;
            const icons = { success: '✅', error: '❌', info: 'ℹ️', warning: '⚠️' };
            const zone = document.getElementById('toastZone');
            const t = document.createElement('div');
            t.className = 'toast ' + type;
            t.innerHTML =
                '<span class="t-icon">' + (icons[type] || 'ℹ️') + '</span>' +
                '<div class="t-body">' +
                    (title ? '<div class="t-title">' + title + '</div>' : '') +
                    '<div class="t-msg">' + msg + '</div>' +
                '</div>' +
                '<button class="t-close" onclick="this.closest(\'.toast\').remove()">×</button>';
            zone.appendChild(t);
            setTimeout(() => {
                t.style.animation = 'toast-out .35s forwards';
                setTimeout(() => t.remove(), 370);
            }, duration);
        };

        /* ── Auto TempData toasts ── */
        var _ti = '@TempData["info"]';
        var _te = '@TempData["Error"]';
        var _ts = '@TempData["Success"]';
        if (_ti && _ti !== '') SabiToast(_ti, 'info');
        if (_te && _te !== '') SabiToast(_te, 'error');
        if (_ts && _ts !== '') SabiToast(_ts, 'success');

        /* ── Newsletter subscribe ── */
        function subscribeNewsletter() {
            var email = document.getElementById('newsletterEmail').value.trim();
            if (!email || !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                SabiToast('Please enter a valid email address.', 'warning');
                return;
            }
            SabiToast('You\'re subscribed! Welcome to SabiSpace updates 🎉', 'success', 5000, 'Subscribed!');
            document.getElementById('newsletterEmail').value = '';
        }

        /* ── Fade-up scroll observer ── */
        var fadeEls = document.querySelectorAll('.fade-up');
        if (fadeEls.length) {
            var io = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (e.isIntersecting) {
                        e.target.classList.add('visible');
                        io.unobserve(e.target);
                    }
                });
            }, { threshold: 0.1 });
            fadeEls.forEach(function (el) { io.observe(el); });
        }

        /* ── Global search (stub) ── */
        document.getElementById('globalSearch').addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && this.value.trim()) {
                SabiToast('Searching for "' + this.value.trim() + '"…', 'info');
            }
        });
    </script>
</body>
</html>
