<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SabiSpace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />

    
    <style>
        /* ═══════════════════════════════════════════
               TOKENS
            ═══════════════════════════════════════════ */
        :root {
            --sabi: #ff5c1a;
            --sabi-h: #ff7340;
            --sabi-dim: rgba(255,92,26,.14);
            --sabi-ring: rgba(255,92,26,.24);
            --gold: #f5c842;
            --gold-dim: rgba(245,200,66,.13);
            --sage: #3dba8c;
            --sky: #1a7cff;
            --ink: #0b0c0f;
            --ink2: #13151c;
            --ink3: #1a1d27;
            --ink4: #21242f;
            --muted: #6b7280;
            --text-primary: #f0ede8;
            --text-secondary: #a09a93;
            --text-dim: #5c5650;
            --border: rgba(255,255,255,.07);
            --border2: rgba(255,255,255,.12);
            --nav-h: 68px;
            --ease: cubic-bezier(.22,1,.36,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--ink);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ═══════════════════════════════════════════
               ANNOUNCEMENT BAR
            ═══════════════════════════════════════════ */
        .announce-bar {
            background: linear-gradient(90deg, var(--sabi), #e03d00);
            padding: 9px 5vw;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 13px;
            font-weight: 500;
            color: #fff;
            position: relative;
            z-index: 1000;
        }

            .announce-bar a {
                color: var(--gold);
                text-decoration: none;
                font-weight: 700;
                border-bottom: 1px solid rgba(245,200,66,.4);
                transition: border-color .2s;
            }

                .announce-bar a:hover {
                    border-color: var(--gold);
                }

        .announce-close {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255,255,255,.7);
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
            padding: 0;
            transition: color .2s;
        }

            .announce-close:hover {
                color: #fff;
            }

        /* ═══════════════════════════════════════════
               NAV
            ═══════════════════════════════════════════ */
        .nav {
            position: sticky;
            top: 0;
            z-index: 900;
            height: var(--nav-h);
            display: flex;
            align-items: center;
            padding: 0 5vw;
            background: rgba(11,12,15,.82);
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            border-bottom: 1px solid var(--border);
            transition: background .3s, box-shadow .3s;
            gap: 0;
        }

            .nav.scrolled {
                background: rgba(11,12,15,.97);
                box-shadow: 0 4px 32px rgba(0,0,0,.4);
            }

        /* Brand */
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
            margin-right: 36px;
        }

        .nav-logo {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            background: var(--sabi);
            display: grid;
            place-items: center;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 17px;
            color: #fff;
            position: relative;
            box-shadow: 0 0 18px rgba(255,92,26,.4);
        }

            .nav-logo::after {
                content: '';
                position: absolute;
                inset: -3px;
                border-radius: 14px;
                border: 2px solid var(--sabi);
                opacity: 0;
                animation: logo-ring 2.8s ease-in-out infinite;
            }

        @@keyframes logo-ring {
            0%, 100% {
                opacity: 0;
                transform: scale(1)
            }

            50% {
                opacity: .4;
                transform: scale(1.14)
            }
        }

        .nav-wordmark {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.2rem;
            letter-spacing: -.4px;
            color: var(--text-primary);
        }

            .nav-wordmark span {
                color: var(--sabi);
            }

        /* Search bar */
        .nav-search {
            flex: 1;
            max-width: 320px;
            position: relative;
            margin-right: auto;
        }

            .nav-search input {
                width: 100%;
                padding: 9px 16px 9px 38px;
                background: rgba(255,255,255,.05);
                border: 1.5px solid var(--border2);
                border-radius: 50px;
                color: var(--text-primary);
                font-family: 'DM Sans', sans-serif;
                font-size: 13px;
                outline: none;
                transition: background .2s, border-color .2s, box-shadow .2s;
            }

                .nav-search input::placeholder {
                    color: var(--text-dim);
                }

                .nav-search input:focus {
                    background: rgba(255,255,255,.08);
                    border-color: var(--sabi);
                    box-shadow: 0 0 0 3px var(--sabi-ring);
                }

        .nav-search-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-dim);
            font-size: 14px;
            pointer-events: none;
        }

        /* Nav links */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            margin-left: 32px;
        }

            .nav-links a {
                display: flex;
                align-items: center;
                gap: 5px;
                padding: 7px 13px;
                border-radius: 10px;
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                transition: color .2s, background .2s;
                white-space: nowrap;
                position: relative;
            }

                .nav-links a:hover {
                    color: var(--text-primary);
                    background: rgba(255,255,255,.06);
                }

                .nav-links a.active {
                    color: var(--text-primary);
                    background: rgba(255,255,255,.06);
                }

                    .nav-links a.active::after {
                        content: '';
                        position: absolute;
                        bottom: -1px;
                        left: 13px;
                        right: 13px;
                        height: 2px;
                        background: var(--sabi);
                        border-radius: 2px;
                    }
        /* Nav badge */
        .nav-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 18px;
            height: 18px;
            padding: 0 5px;
            background: var(--sabi);
            border-radius: 9px;
            font-size: 10px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        /* Right side actions */
        .nav-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: 24px;
        }

        /* Icon button */
        .nav-icon-btn {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            border: 1.5px solid var(--border2);
            background: rgba(255,255,255,.04);
            display: grid;
            place-items: center;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all .2s;
            position: relative;
            flex-shrink: 0;
            text-decoration: none;
        }

            .nav-icon-btn:hover {
                color: var(--text-primary);
                background: rgba(255,255,255,.08);
                border-color: rgba(255,255,255,.18);
            }

        .nav-notif-dot {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--sabi);
            border: 1.5px solid var(--ink);
        }

        /* CTA buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 20px;
            border-radius: 50px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 13.5px;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all .2s;
            white-space: nowrap;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-secondary);
            border: 1.5px solid var(--border2);
        }

            .btn-ghost:hover {
                color: var(--text-primary);
                border-color: rgba(255,255,255,.22);
                background: rgba(255,255,255,.06);
            }

        .btn-sabi {
            background: var(--sabi);
            color: #fff;
            box-shadow: 0 4px 16px rgba(255,92,26,.35);
        }

            .btn-sabi:hover {
                background: var(--sabi-h);
                box-shadow: 0 6px 22px rgba(255,92,26,.5);
                transform: translateY(-1px);
                color: #fff;
            }

        /* Hamburger */
        .nav-burger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 8px;
            margin-left: auto;
        }

            .nav-burger span {
                width: 22px;
                height: 2px;
                background: var(--text-primary);
                border-radius: 2px;
                transition: all .3s var(--ease);
                display: block;
            }

            .nav-burger.open span:nth-child(1) {
                transform: rotate(45deg) translate(5px,5px);
            }

            .nav-burger.open span:nth-child(2) {
                opacity: 0;
                transform: scaleX(0);
            }

            .nav-burger.open span:nth-child(3) {
                transform: rotate(-45deg) translate(5px,-5px);
            }

        /* Mobile drawer */
        .nav-drawer {
            position: fixed;
            top: var(--nav-h);
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(11,12,15,.98);
            backdrop-filter: blur(24px);
            z-index: 899;
            padding: 24px 5vw 40px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transform: translateX(100%);
            transition: transform .35s var(--ease);
            overflow-y: auto;
        }

            .nav-drawer.open {
                transform: translateX(0);
            }

            .nav-drawer a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 14px 16px;
                border-radius: 14px;
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 15px;
                font-weight: 500;
                border: 1px solid transparent;
                transition: all .2s;
            }

                .nav-drawer a:hover, .nav-drawer a.active {
                    color: var(--text-primary);
                    background: rgba(255,255,255,.05);
                    border-color: var(--border);
                }

                .nav-drawer a.active {
                    color: var(--sabi);
                    border-color: var(--sabi-dim);
                    background: var(--sabi-dim);
                }

        .drawer-sep {
            height: 1px;
            background: var(--border);
            margin: 12px 0;
        }

        .drawer-btns {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 8px;
        }

            .drawer-btns .btn {
                width: 100%;
                justify-content: center;
                border-radius: 14px;
                padding: 13px 20px;
            }

        /* ═══════════════════════════════════════════
               PROGRESS BAR (page load)
            ═══════════════════════════════════════════ */
        .progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 9999;
            height: 3px;
            width: 0%;
            background: linear-gradient(90deg, var(--sabi), var(--gold));
            border-radius: 0 2px 2px 0;
            box-shadow: 0 0 12px rgba(255,92,26,.6);
            transition: width .3s ease, opacity .4s ease;
            pointer-events: none;
        }

        /* ═══════════════════════════════════════════
               TOAST
            ═══════════════════════════════════════════ */
        .toast-zone {
            position: fixed;
            bottom: 28px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
        }

        .toast {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 18px;
            border-radius: 16px;
            min-width: 260px;
            max-width: 360px;
            background: var(--ink2);
            border: 1px solid var(--border);
            box-shadow: 0 12px 40px rgba(0,0,0,.5);
            font-size: 13.5px;
            font-weight: 500;
            pointer-events: all;
            animation: toast-in .35s var(--ease);
            color: var(--text-primary);
        }

            .toast.success {
                border-left: 3px solid var(--sage);
            }

            .toast.error {
                border-left: 3px solid #f87171;
            }

            .toast.info {
                border-left: 3px solid var(--sky);
            }

            .toast.warning {
                border-left: 3px solid var(--gold);
            }

        .t-icon {
            font-size: 16px;
            flex-shrink: 0;
        }

        .t-body {
            flex: 1;
        }

        .t-title {
            font-weight: 700;
            font-size: 13px;
            margin-bottom: 1px;
        }

        .t-msg {
            font-size: 12.5px;
            color: var(--text-secondary);
        }

        .t-close {
            background: none;
            border: none;
            color: var(--text-dim);
            cursor: pointer;
            font-size: 16px;
            padding: 0;
            flex-shrink: 0;
            line-height: 1;
            transition: color .2s;
        }

            .t-close:hover {
                color: var(--text-primary);
            }

        @@keyframes toast-in {
            from {
                opacity: 0;
                transform: translateY(12px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @@keyframes toast-out {
            to {
                opacity: 0;
                transform: translateY(12px)
            }
        }

        /* ═══════════════════════════════════════════
               MAIN
            ═══════════════════════════════════════════ */
        main {
            min-height: calc(100vh - var(--nav-h));
        }

        /* ═══════════════════════════════════════════
               FOOTER
            ═══════════════════════════════════════════ */
        footer {
            background: var(--ink2);
            border-top: 1px solid var(--border);
            padding: 72px 5vw 0;
            position: relative;
            overflow: hidden;
        }
            /* Subtle footer glow */
            footer::before {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 320px;
                background: radial-gradient(ellipse at 50% 100%, rgba(255,92,26,.06) 0%, transparent 70%);
                pointer-events: none;
            }

        .footer-top {
            display: grid;
            grid-template-columns: 1.8fr 1fr 1fr 1fr;
            gap: 56px;
            padding-bottom: 56px;
            border-bottom: 1px solid var(--border);
            position: relative;
            z-index: 1;
        }

        /* Brand col */
        .footer-brand {
        }

        .footer-brand-logo {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            margin-bottom: 16px;
        }

        .footer-logo-mark {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            background: var(--sabi);
            display: grid;
            place-items: center;
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 17px;
            color: #fff;
        }

        .footer-wordmark {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.2rem;
            letter-spacing: -.4px;
            color: var(--text-primary);
        }

            .footer-wordmark span {
                color: var(--sabi);
            }

        .footer-desc {
            font-size: 13.5px;
            color: var(--text-secondary);
            line-height: 1.75;
            max-width: 270px;
            margin-bottom: 24px;
        }

        /* Newsletter */
        .footer-newsletter {
            display: flex;
            gap: 8px;
        }

            .footer-newsletter input {
                flex: 1;
                padding: 10px 14px;
                background: rgba(255,255,255,.05);
                border: 1.5px solid var(--border2);
                border-radius: 10px;
                color: var(--text-primary);
                font-family: 'DM Sans', sans-serif;
                font-size: 13px;
                outline: none;
                transition: border-color .2s, box-shadow .2s;
            }

                .footer-newsletter input::placeholder {
                    color: var(--text-dim);
                }

                .footer-newsletter input:focus {
                    border-color: var(--sabi);
                    box-shadow: 0 0 0 3px var(--sabi-ring);
                }

            .footer-newsletter button {
                padding: 10px 18px;
                border-radius: 10px;
                background: var(--sabi);
                border: none;
                color: #fff;
                font-family: 'DM Sans', sans-serif;
                font-size: 13px;
                font-weight: 600;
                cursor: pointer;
                transition: background .2s;
                white-space: nowrap;
            }

                .footer-newsletter button:hover {
                    background: var(--sabi-h);
                }

        /* Footer cols */
        .footer-col h5 {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1.4px;
            color: var(--text-dim);
            margin-bottom: 20px;
        }

        .footer-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 11px;
        }

            .footer-col ul li a {
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 14px;
                transition: color .2s;
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .footer-col ul li a:hover {
                    color: var(--sabi);
                }

                .footer-col ul li a .badge-new {
                    font-size: 10px;
                    font-weight: 700;
                    padding: 2px 6px;
                    border-radius: 4px;
                    background: var(--gold-dim);
                    color: var(--gold);
                    border: 1px solid rgba(245,200,66,.2);
                }

        /* Footer bottom */
        .footer-bottom {
            padding: 24px 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            position: relative;
            z-index: 1;
        }

        .footer-bottom-left {
            display: flex;
            align-items: center;
            gap: 24px;
            flex-wrap: wrap;
        }

        .footer-copy {
            font-size: 13px;
            color: var(--text-dim);
        }

        .footer-legal {
            display: flex;
            gap: 18px;
        }

            .footer-legal a {
                font-size: 13px;
                color: var(--text-dim);
                text-decoration: none;
                transition: color .2s;
            }

                .footer-legal a:hover {
                    color: var(--text-secondary);
                }

        /* Social icons */
        .footer-social {
            display: flex;
            gap: 8px;
        }

        .social-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255,255,255,.05);
            border: 1px solid var(--border);
            display: grid;
            place-items: center;
            color: var(--text-dim);
            text-decoration: none;
            font-size: 13px;
            transition: all .2s;
        }

            .social-icon:hover {
                background: var(--sabi-dim);
                border-color: rgba(255,92,26,.25);
                color: var(--sabi);
                transform: translateY(-2px);
            }

        /* ═══════════════════════════════════════════
               UTILITIES
            ═══════════════════════════════════════════ */
        .fade-up {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity .6s var(--ease), transform .6s var(--ease);
        }

            .fade-up.visible {
                opacity: 1;
                transform: none;
            }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: var(--ink);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--ink4);
            border-radius: 3px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: var(--ink3);
            }

        /* ═══════════════════════════════════════════
               RESPONSIVE
            ═══════════════════════════════════════════ */
        @@media (max-width: 1024px) {
            .nav-search {
                max-width: 220px;
            }

            .footer-top {
                grid-template-columns: 1fr 1fr;
                gap: 40px;
            }
        }

        @@media (max-width: 768px) {
            .nav-search, .nav-links, .nav-actions {
                display: none;
            }

            .nav-burger {
                display: flex;
            }

            .announce-bar {
                font-size: 12px;
            }
        }

        @@media (max-width: 480px) {
            .footer-top {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer-bottom {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
            }

            .footer-bottom-left {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
        }
    </style>

    @* Page styles load AFTER — they always win *@
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ── PAGE LOAD PROGRESS BAR ── -->
    <div class="progress-bar" id="progressBar"></div>

    <!-- ── ANNOUNCEMENT BAR ── -->
    <div class="announce-bar" id="announceBar">
        <span>🎉 New — Live lessons now available for SS3 &amp; Higher!</span>
        <a asp-controller="Lesson" asp-action="Index">Explore now →</a>
        <button class="announce-close" onclick="dismissAnnounce()" aria-label="Close">×</button>
    </div>

    <!-- ═══════════════════════════════════════════
         NAV
    ═══════════════════════════════════════════ -->
    <nav class="nav" id="mainNav">

        <!-- Brand -->
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <div class="nav-logo">S</div>
            <span class="nav-wordmark">Sabi<span>Space</span></span>
        </a>

        <!-- Search -->
        <div class="nav-search">
            <span class="nav-search-icon">⌕</span>
            <input type="search" placeholder="Search lessons, courses…" id="globalSearch" autocomplete="off" />
        </div>

        <!-- Links -->
        <ul class="nav-links">
            <li>
                <a asp-controller="Home" asp-action="Index"
