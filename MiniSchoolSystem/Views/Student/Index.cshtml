@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // All data passed via ViewBag from StudentController.Index()
    var courses = ViewBag.Courses as List<MiniSchoolSystem.Models.Course> ?? new();
    int completedLessons = ViewBag.CompletedLessons ?? 0;
    int totalStudents = ViewBag.TotalStudents ?? 0;
    int totalCourses = ViewBag.TotalCourses ?? 0;
    int pageNumber = ViewBag.PageNumber ?? 1;
    int pageSize = ViewBag.PageSize ?? 15;
    int totalPages = ViewBag.TotalPages ?? 1;
    string studentSection = ViewBag.StudentSection ?? "";
    string studentName = User.Identity?.Name ?? "Student";
    string nameInitial = studentName.Length > 0 ? studentName[0].ToString().ToUpper() : "S";
}

@section Styles {
    <link rel="stylesheet" href="~/css/sabispace.css" asp-append-version="true" />
    <style>
        /* ── Student-specific overrides ── */
        .student-page {
            min-height: 100vh;
            background: var(--bg);
        }

        /* Progress ring */
        .prog-ring {
            transform: rotate(-90deg);
        }

        .ring-track {
            fill: none;
            stroke: rgba(255,255,255,.07);
            stroke-width: 5;
        }

        .ring-prog {
            fill: none;
            stroke: var(--sabi);
            stroke-width: 5;
            stroke-linecap: round;
            stroke-dasharray: 188;
            stroke-dashoffset: 188;
            transition: stroke-dashoffset 1s ease;
        }

        /* Course progress bar inside card */
        .course-prog-wrap {
            margin-top: 12px;
        }

        .course-prog-bar {
            height: 4px;
            background: rgba(255,255,255,.07);
            border-radius: 2px;
            overflow: hidden;
        }

        .course-prog-fill {
            height: 100%;
            border-radius: 2px;
            background: linear-gradient(90deg,var(--sabi),var(--gold));
            transition: width .8s ease;
            width: 0;
        }

        .course-prog-pct {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 4px;
        }

        /* Section badge */
        .section-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
            background: var(--sabi-dim);
            border: 1px solid rgba(255,92,26,.22);
            color: var(--sabi);
        }

        /* Enrollment status pill */
        .enroll-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
        }

        .ep-enrolled {
            background: var(--sage-dim);
            border: 1px solid rgba(61,186,140,.25);
            color: var(--sage);
        }

        .ep-inprogress {
            background: var(--sabi-dim);
            border: 1px solid rgba(255,92,26,.22);
            color: var(--sabi);
        }

        .ep-done {
            background: rgba(245,200,66,.1);
            border: 1px solid rgba(245,200,66,.25);
            color: var(--gold);
        }

        /* Quick-action card */
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 28px;
        }

        .qa-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
            text-decoration: none;
            color: inherit;
            transition: all .2s;
        }

            .qa-card:hover {
                transform: translateY(-3px);
                border-color: var(--border2);
                box-shadow: 0 12px 32px rgba(0,0,0,.3);
            }

        .qa-icon {
            font-size: 24px;
        }

        .qa-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .qa-sub {
            font-size: 12px;
            color: var(--text-secondary);
            margin-top: -6px;
        }

        /* Empty courses state */
        .no-courses {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 20px;
        }

        /* Pagination */
        .pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 32px;
        }

        .pg-btn {
            padding: 8px 16px;
            border-radius: 10px;
            border: 1.5px solid var(--border2);
            background: rgba(128,128,128,.06);
            color: var(--text-secondary);
            font-family: 'DM Sans',sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
        }

            .pg-btn:hover {
                background: rgba(128,128,128,.12);
                color: var(--text-primary);
            }

            .pg-btn.active {
                background: var(--sabi);
                border-color: var(--sabi);
                color: #fff;
            }

            .pg-btn:disabled {
                opacity: .4;
                cursor: not-allowed;
            }

        /* Responsive */
        @@media(max-width:1024px) {
            .quick-actions {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media(max-width:640px) {
            .quick-actions {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
}

<div class="student-page">

    <!-- ═══════════════════════════════════
         PORTAL WRAP — sidebar + main
    ════════════════════════════════════ -->
    <div class="portal-wrap">

        <!-- ── SIDEBAR ── -->
        <aside class="sidebar" id="sidebar">

            <a href="/" class="sidebar-logo">
                <div class="sidebar-logo-mark">S</div>
                <span class="sidebar-logo-text">Sabi<span>Space</span></span>
            </a>

            <!-- Student profile pill -->
            <div class="sidebar-profile">
                <div class="profile-av">@nameInitial</div>
                <div>
                    <div class="profile-name">@studentName</div>
                    <div class="profile-role">
                        Student
                        @if (!string.IsNullOrEmpty(studentSection))
                        {
                            <span style="color:var(--sabi)"> · @studentSection</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Nav -->
            <div class="nav-section">
                <div class="nav-section-label">Learning</div>
                <a class="nav-item active" href="/Student" data-path="/student">
                    <span class="nav-icon">🏠</span> Dashboard
                </a>
                <a class="nav-item" href="/Lesson" data-path="/lesson">
                    <span class="nav-icon">🎓</span> Lessons
                    <span class="nav-badge">Live</span>
                </a>
                <a class="nav-item" href="/Course" data-path="/course">
                    <span class="nav-icon">📚</span> Courses
                </a>
                <a class="nav-item" href="/Quiz" data-path="/quiz">
                    <span class="nav-icon">🧠</span> Quizzes
                </a>
                <a class="nav-item" href="/Assignment" data-path="/assignment">
                    <span class="nav-icon">📝</span> Assignments
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-label">Account</div>
                <button class="nav-item" onclick="SabiToast('Progress tracking coming soon!','info')">
                    <span class="nav-icon">📊</span> My Progress
                    <span class="nav-badge coming">Soon</span>
                </button>
                <button class="nav-item" onclick="SabiToast('Certificates coming soon!','info')">
                    <span class="nav-icon">🏅</span> Certificates
                    <span class="nav-badge coming">Soon</span>
                </button>
                <a class="nav-item" href="/Profile" data-path="/profile">
                    <span class="nav-icon">👤</span> My Profile
                </a>
            </div>

            <!-- Sidebar footer — sign out -->
            <div class="sidebar-footer">
                <form asp-controller="Auth" asp-action="Logout" method="post" style="display:contents">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-item" style="width:100%">
                        <span class="nav-icon">🚪</span>
                        <span style="color:#f87171">Sign Out</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ── MOBILE OVERLAY ── -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- ═══════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════ -->
        <div class="main-content">

            <!-- Mobile top bar -->
            <div class="mobile-topbar">
                <button class="mobile-menu-btn" onclick="openSidebar()" aria-label="Menu">☰</button>
                <span style="font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text-primary)">
                    My Dashboard
                </span>
                <div style="width:36px"></div>
            </div>

            <!-- Top bar -->
            <div class="topbar">
                <span class="topbar-title">Student Dashboard</span>
                <div class="topbar-right">
                    @if (!string.IsNullOrEmpty(studentSection))
                    {
                        <span class="section-badge">📋 @studentSection</span>
                    }
                    <button class="notif-btn" onclick="SabiToast('No new notifications','info')" aria-label="Notifications">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 01-3.46 0" />
                        </svg>
                        <span class="notif-dot"></span>
                    </button>
                </div>
            </div>

            <!-- ── PAGE BODY ── -->
            <div class="page-body">

                <!-- Header -->
                <div class="page-body-header">
                    <h1 class="page-body-title">Welcome back, @studentName.Split(' ')[0] 👋</h1>
                    <p class="page-body-sub">Here's your learning snapshot. Keep going — every lesson counts.</p>
                </div>

                <!-- TempData toasts handled by layout — no inline needed -->
                <!-- ── STAT CARDS ── -->
                <div class="stats-grid" style="grid-template-columns:repeat(4,1fr)">
                    <div class="stat-card sabi">
                        <div class="stat-icon si-sabi">📚</div>
                        <div class="stat-num" data-counter="@totalCourses">@totalCourses</div>
                        <div class="stat-label">Enrolled Courses</div>
                    </div>
                    <div class="stat-card sage">
                        <div class="stat-icon si-sage">✅</div>
                        <div class="stat-num" data-counter="@completedLessons">@completedLessons</div>
                        <div class="stat-label">Lessons Completed</div>
                    </div>
                    <div class="stat-card gold">
                        <div class="stat-icon si-gold">🧠</div>
                        <div class="stat-num" data-counter="0">0</div>
                        <div class="stat-label">Quizzes Taken</div>
                        <span class="stat-delta delta-new">Soon</span>
                    </div>
                    <div class="stat-card sky">
                        <div class="stat-icon si-sky">🏅</div>
                        <div class="stat-num" data-counter="0">0</div>
                        <div class="stat-label">Certificates Earned</div>
                        <span class="stat-delta delta-new">Soon</span>
                    </div>
                </div>

                <!-- ── QUICK ACTIONS ── -->
                <div class="quick-actions">
                    <a asp-controller="Lesson" asp-action="Index" class="qa-card">
                        <div class="qa-icon">🎓</div>
                        <div class="qa-label">Browse Lessons</div>
                        <div class="qa-sub">Find your next lesson</div>
                    </a>
                    <a asp-controller="Quiz" asp-action="Index" class="qa-card">
                        <div class="qa-icon">🧠</div>
                        <div class="qa-label">Take a Quiz</div>
                        <div class="qa-sub">Test your knowledge</div>
                    </a>
                    <a asp-controller="Assignment" asp-action="Index" class="qa-card">
                        <div class="qa-icon">📝</div>
                        <div class="qa-label">Assignments</div>
                        <div class="qa-sub">Submit your work</div>
                    </a>
                    <a asp-controller="Course" asp-action="Index" class="qa-card">
                        <div class="qa-icon">📚</div>
                        <div class="qa-label">All Courses</div>
                        <div class="qa-sub">Explore the catalogue</div>
                    </a>
                </div>

                <!-- ── MY COURSES ── -->
                <div class="section-card">
                    <div class="section-card-header">
                        <div class="section-card-title">
                            📚 My Courses
                            @if (!string.IsNullOrEmpty(studentSection))
                            {
                                <span class="section-badge" style="font-size:11px">@studentSection</span>
                            }
                        </div>
                        <a asp-controller="Course" asp-action="Index"
                           class="btn btn-ghost btn-sm" style="border-radius:50px">View all →</a>
                    </div>

                    <div class="section-card-body">
                        @if (!courses.Any())
                        {
                            <div class="no-courses">
                                <div style="font-size:48px;margin-bottom:14px">📭</div>
                                <h3 style="font-family:'Syne',sans-serif;font-weight:700;font-size:1.2rem;color:var(--text-primary);margin-bottom:8px">
                                    No courses yet
                                </h3>
                                <p style="font-size:14px;color:var(--text-secondary);margin-bottom:20px;max-width:320px;margin-left:auto;margin-right:auto">
                                    Courses matching your curriculum section (@studentSection) will appear here once a teacher creates them.
                                </p>
                                <a asp-controller="Course" asp-action="Index" class="btn btn-sabi" style="border-radius:50px">
                                    Browse All Courses →
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="courses-grid" style="grid-template-columns:repeat(3,1fr)">
                                @foreach (var course in courses)
                                {// 1. Get Module Count safely
                             var modules = course.CourseModules?.Count ?? 0;

                                    // 2. Get Total Lessons safely using SelectMany
                            var totalLessons = course.CourseModules?
                               .SelectMany(m => m.Lessons ?? new List<Lesson>())
                                    .Count() ?? 0;

                                    string[] bgGrads = {
                                                        "linear-gradient(135deg,#1a1c22,#2a1810)",
                                                        "linear-gradient(135deg,#0c1a12,#1a2a1a)",
                                                        "linear-gradient(135deg,#1a1228,#0c1020)",
                                                        "linear-gradient(135deg,#1a1500,#2a2000)",
                                                        "linear-gradient(135deg,#001a1a,#001028)"
                                                        };
                                    string[] thumbs = { "💻", "📊", "🎨", "💰", "🤖", "🧪", "📐", "🌍", "📖", "🎵" };
                                    int idx = course.Id % thumbs.Length;

                                    <div class="course-card">
                                        <div class="course-thumb" style="background:@bgGrads[course.Id % bgGrads.Length]">
                                            @thumbs[idx]
                                            <div class="course-thumb-overlay">
                                                <div class="course-thumb-actions">
                                                    <a asp-controller="Course" asp-action="Details"
                                                       asp-route-id="@course.Id"
                                                       class="thumb-action-btn tab-view">View</a>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="course-body">
                                            <div class="course-section-tag">@course.CourseSections</div>
                                            <div class="course-title">@course.Title</div>
                                            <div class="course-meta">
                                                <span class="course-meta-item">📦 @modules module@(modules != 1 ? "s" : "")</span>
                                                <span class="course-meta-item">🎓 @totalLessons lesson@(totalLessons != 1 ? "s" : "")</span>
                                                <span class="course-meta-item">📅 @course.CreatedAt.ToString("dd MMM yyyy")</span>
                                            </div>
                                            <!-- Progress bar (0% until tracking is wired) -->
                                            <div class="course-prog-wrap">
                                                <div class="course-prog-bar">
                                                    <div class="course-prog-fill" data-pct="0"></div>
                                                </div>
                                                <div class="course-prog-pct">0% complete</div>
                                            </div>
                                            <!-- Module accordion -->
                                            @if (course.CourseModules != null && course.CourseModules.Any())
                                            {
                                                <div class="module-list" style="margin-top:12px">
                                                    @foreach (var (mod, mi) in course.CourseModules.Select((m, i) => (m, i)))
                                                    {
                                                        <div class="module-item" id="mod-@mod.Id" data-module-id="@mod.Id">
                                                            <div class="module-header" onclick="toggleModule(document.getElementById('mod-@mod.Id'))">
                                                                <div class="module-num">@(mi + 1)</div>
                                                                <div class="module-title">@mod.Title</div>
                                                                <span class="module-chevron">▾</span>
                                                            </div>
                                                            <div class="module-body">
                                                                <div class="lesson-list">
                                                                    @if (mod.Lessons != null && mod.Lessons.Any())
                                                                    {
                                                                        @foreach (var lesson in mod.Lessons.Take(5))
                                                                        {
                                                                            <a class="lesson-row"
                                                                               asp-controller="Student"
                                                                               asp-action="CreateLessonEnrollment"
                                                                               asp-route-lessonId="@lesson.Id">
                                                                                <span class="lesson-row-icon">📄</span>
                                                                                <span class="lesson-row-title">@lesson.Title</span>
                                                                                <span class="lesson-row-date">@lesson.CreatedAt.ToString("dd MMM")</span>
                                                                            </a>
                                                                        }
                                                                        @if (mod.Lessons.Count > 5)
                                                                        {
                                                                            <div style="padding:8px 12px;font-size:12px;color:var(--text-dim)">
                                                                                +@(mod.Lessons.Count - 5) more lessons
                                                                            </div>
                                                                        }
                                                                    }
                                                                    else
                                                                    {
                                                                        <div style="padding:10px 12px;font-size:12.5px;color:var(--text-dim)">No lessons yet.</div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Pagination -->
                            @if (totalPages > 1)
                            {
                                <div class="pagination">
                                    @if (pageNumber > 1)
                                    {
                                        <a asp-action="Index"
                                           asp-route-pageNumber="@(pageNumber - 1)"
                                           asp-route-pageSize="@pageSize"
                                           class="pg-btn">← Previous</a>
                                    }
                                    else
                                    {
                                        <button class="pg-btn" disabled>← Previous</button>
                                    }

                                    @for (int p = 1; p <= totalPages; p++)
                                    {
                                        <a asp-action="Index"
                                           asp-route-pageNumber="@p"
                                           asp-route-pageSize="@pageSize"
                                           class="pg-btn @(p == pageNumber ? "active" : "")">@p</a>
                                    }

                                    @if (pageNumber < totalPages)
                                    {
                                        <a asp-action="Index"
                                           asp-route-pageNumber="@(pageNumber + 1)"
                                           asp-route-pageSize="@pageSize"
                                           class="pg-btn">Next →</a>
                                    }
                                    else
                                    {
                                        <button class="pg-btn" disabled>Next →</button>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- ── COMING SOON CARDS ── -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:8px">
                    <div class="section-card">
                        <div class="section-card-header">
                            <div class="section-card-title">📊 My Progress</div>
                            <span class="coming-soon-badge"><span class="cs-dot"></span>Coming Soon</span>
                        </div>
                        <div class="section-card-body">
                            <div class="empty-state">
                                <div class="empty-icon">📈</div>
                                <div class="empty-title">Progress tracking</div>
                                <p class="empty-body">Your quiz scores, lesson completion and overall course progress will show here.</p>
                            </div>
                        </div>
                    </div>
                    <div class="section-card">
                        <div class="section-card-header">
                            <div class="section-card-title">🏅 My Certificates</div>
                            <span class="coming-soon-badge"><span class="cs-dot"></span>Coming Soon</span>
                        </div>
                        <div class="section-card-body">
                            <div class="empty-state">
                                <div class="empty-icon">🎖️</div>
                                <div class="empty-title">Certificates</div>
                                <p class="empty-body">Complete a full course to earn a verified SabiSpace certificate you can share anywhere.</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- end page-body -->
        </div><!-- end main-content -->
    </div><!-- end portal-wrap -->
</div>

@section Scripts {
    <script src="~/js/sabispace.js" asp-append-version="true"></script>
    <script>
        // Animate progress bar fills
        document.querySelectorAll('.course-prog-fill[data-pct]').forEach(function(el) {
            setTimeout(function() { el.style.width = (el.dataset.pct || '0') + '%'; }, 300);
        });
    </script>
}
